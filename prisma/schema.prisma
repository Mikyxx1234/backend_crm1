/// Configuracao do layout mobile (PWA) — quais modulos aparecem na
/// bottom nav, ordem, e onde o app abre. Hoje e singleton (uma row
/// global pra organizacao). Quando virarmos multi-tenant, basta
/// trocar `id` por `organizationId` e adicionar a relacao — o
/// codigo do front ja consome via /api/mobile-layout, isolando.
///
/// Decisoes:
/// - `bottomNavModuleIds`: array ordenado, max 5 itens (limite UX
/// pra bottom nav nao quebrar em telas pequenas). O resto cai
/// no MobileMoreSheet automaticamente.
/// - `enabledModuleIds`: subset de TODOS os modulos disponiveis.
/// Modulos fora dessa lista NAO aparecem nem no bottom nav nem
/// no MoreSheet (admin "esconde" features irrelevantes do app).
/// - `startRoute`: rota inicial ao abrir o PWA (default /inbox).
/// - `version`: incrementado a cada save — usado pra cache-bust no
/// front (SWR/React Query refeed).
model MobileLayoutConfig {
  id                 String       @id @default(cuid())
  /// Uma linha por organização (antes era singleton global). `@@unique`
  /// garante que o upsert em `/api/mobile-layout` continue funcionando
  /// sem precisar de lógica extra — chave = organizationId.
  organizationId     String       @unique
  /// Slugs separados por virgula. Mantemos string em vez de array
  /// pra simplificar serializacao e evitar dependencia de extensoes
  /// Postgres. Ex.: "inbox,pipeline,tasks,contacts,more".
  bottomNavModuleIds String       @default("inbox,pipeline,tasks,contacts")
  /// Slugs separados por virgula. Ex.: "inbox,pipeline,tasks,contacts,companies,settings,profile".
  enabledModuleIds   String       @default("inbox,pipeline,tasks,contacts,companies,settings,profile")
  startRoute         String       @default("/inbox")
  /// Cor de marca opcional (override do navy padrao). Hex.
  /// Quando null, usa o brand-navy global.
  brandColor         String?
  /// Versao incrementada a cada PUT — front faz refetch quando muda.
  version            Int          @default(1)
  updatedAt          DateTime     @updatedAt
  updatedBy          String?
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("mobile_layout_config")
}

/// Subscription do Push API (W3C) por dispositivo do operador. Um
/// usuario pode ter N subscriptions (mobile + desktop + outro
/// browser). O `endpoint` e unico globalmente (incluindo a URL de
/// FCM/Mozilla autopush) — fazemos UPSERT por endpoint pra lidar
/// com reinstall de PWA / re-subscription.
model WebPushSubscription {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  /// URL do push service (FCM, Mozilla autopush, Apple). Unica
  /// globalmente — eh o "ID" da subscription pro browser.
  endpoint       String       @unique
  /// Chave publica P-256 do cliente (base64url). Usada pelo VAPID
  /// pra criptografar o payload.
  p256dh         String
  /// Auth secret (base64url). Tambem usada na criptografia.
  auth           String
  /// User-Agent capturado no momento da subscription — facilita
  /// "esquecer dispositivo X" no UI.
  userAgent      String?
  createdAt      DateTime     @default(now())
  /// Atualizado a cada disparo bem-sucedido. Permite limpar
  /// subscriptions mortas (>30 dias sem entregar).
  lastUsedAt     DateTime?
  /// Marcado quando o push service retorna 410 Gone — guardamos
  /// pra auditoria antes de deletar definitivamente.
  failedAt       DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([failedAt])
  @@map("web_push_subscriptions")
}

model MetaPricingDailyMetric {
  id              String   @id @default(cuid())
  /// Dia em UTC (00:00:00). Granularity=DAILY na Meta.
  date            DateTime
  /// REGULAR | FREE_CUSTOMER_SERVICE | FREE_ENTRY_POINT | FREE_TIER
  pricingType     String
  /// MARKETING | UTILITY | AUTHENTICATION | SERVICE | AUTHENTICATION_INTERNATIONAL
  pricingCategory String
  /// ISO-2 (BR, US, ...) ou "UNKNOWN" quando a Meta nao retorna.
  country         String   @default("UNKNOWN")
  /// Telefone E.164 (sem '+'). Default '' quando agregado por WABA
  /// (evita NULL distinto no unique composto).
  phoneNumber     String   @default("")
  /// Tier de volume (ex: "TIER_1K", "TIER_10K"). Default '' quando
  /// nao retornado pela Meta.
  tier            String   @default("")
  /// Volume de mensagens nessa combinacao naquele dia.
  volume          Int      @default(0)
  /// Custo em USD (Meta retorna em cents, convertemos antes de salvar).
  cost            Float    @default(0)
  /// Quando esse registro foi atualizado pelo sync. Permite saber
  /// "ultima sincronizacao" no header do relatorio.
  syncedAt        DateTime @default(now()) @updatedAt

  @@unique([date, pricingType, pricingCategory, country, phoneNumber, tier], map: "meta_pricing_unique_combo")
  @@index([date])
  @@index([pricingCategory])
  @@map("meta_pricing_daily_metrics")
}

model AIAgentConfig {
  id                        String                @id @default(cuid())
  organizationId            String
  userId                    String                @unique
  archetype                 AIAgentArchetype      @default(SDR)
  model                     String                @default("gpt-4o-mini")
  temperature               Float                 @default(0.7)
  maxTokens                 Int                   @default(1024)
  /// Prompt-template do arquétipo (renderizado em tempo de execução
  /// com variáveis do contato/deal/conversa). Copiado do catálogo
  /// no momento da criação — depois vive por conta própria.
  systemPromptTemplate      String
  /// Overrides livres escritos pelo admin (adicionados ao final do
  /// systemPromptTemplate). Ex.: tom específico, regras de produto.
  systemPromptOverride      String?
  /// Política dedicada de apresentação de produtos. Injetada no system
  /// prompt apenas quando a tool `search_products` está habilitada.
  /// Dita quais campos do produto priorizar, formato de apresentação,
  /// tom para tratar preço, etc. Formato: texto livre (markdown-like).
  productPolicy             String?
  tone                      String                @default("profissional e cordial")
  language                  String                @default("pt-BR")
  autonomyMode              AIAgentAutonomy       @default(DRAFT)
  /// Lista de tool ids habilitadas (ex.: ["create_deal","add_tag","transfer_to_human"]).
  enabledTools              String[]              @default([])
  /// Limite defensivo diário em tokens (input+output). 0 = ilimitado.
  dailyTokenCap             Int                   @default(0)
  /// Pipeline preferencial para handoff / criação de deal. Se null,
  /// usa o pipeline default do contato (primeiro pipeline ativo).
  pipelineId                String?
  /// Canal preferencial para envio de mensagens. Null = usa o canal
  /// da conversa em que o agente está respondendo.
  channelId                 String?
  active                    Boolean               @default(true)
  /// Mensagem de saudação enviada UMA vez por conversa, antes da
  /// primeira resposta do LLM. Null/empty = desativado. Suporta
  /// variáveis simples: {{contact.firstName}}, {{deal.title}}, etc.
  openingMessage            String?
  /// Delay em ms antes de disparar a saudação (0 = imediato).
  openingDelayMs            Int                   @default(0)
  /// Timer de inatividade em ms. Quando o agente respondeu por último
  /// e o cliente não respondeu por N ms, dispara o handoff configurado.
  /// 0 = desativado.
  inactivityTimerMs         Int                   @default(0)
  /// Modo de handoff: "KEEP_OWNER" (volta pro dono do deal),
  /// "SPECIFIC_USER" (atribui usuário fixo), "UNASSIGN" (deixa na fila).
  inactivityHandoffMode     String                @default("KEEP_OWNER")
  /// Quando mode=SPECIFIC_USER, qual user receber.
  inactivityHandoffUserId   String?
  /// Texto opcional enviado pelo agente antes do handoff.
  inactivityFarewellMessage String?
  /// Lista de gatilhos textuais que forçam handoff imediato
  /// (match case-insensitive por substring na mensagem do cliente).
  keywordHandoffs           String[]              @default([])
  /// Lista de perguntas obrigatórias de qualificação que o agente
  /// deve coletar antes de encerrar/transferir. Formato:
  /// `[{ id, question }, ...]`. Injetado no system prompt.
  qualificationQuestions    Json                  @default("[]")
  /// Configuração de horário de atendimento. Quando `enabled=true` e
  /// o momento atual cai fora do horário, o agente NÃO responde e
  /// envia `offHoursMessage` (ou só registra rascunho se null).
  /// Formato: `{ enabled, timezone, weekdays: [{day,start,end}], offHoursMessage }`.
  businessHours             Json?
  /// Estilo de saída: "conversational" (default, proíbe bullets/ficha
  /// técnica) ou "structured" (permite listas/markdown).
  outputStyle               String                @default("conversational")
  /// Simula comportamento humano: mostra "digitando…" no WhatsApp do
  /// cliente antes de responder e aguarda tempo proporcional ao
  /// tamanho da mensagem. API Meta entrega o indicador por até 25s.
  simulateTyping            Boolean               @default(true)
  /// ms por caractere gerado pra calcular o delay de "digitando".
  /// Total = min(1500 + len * perChar, 25000).
  typingPerCharMs           Int                   @default(25)
  /// Marca a mensagem recebida como lida (tracinhos azuis) antes de
  /// responder. Se `simulateTyping=true`, a marcação de leitura já
  /// acontece implicitamente na mesma chamada.
  markMessagesRead          Boolean               @default(true)
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  organization              Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  knowledgeDocs             AIAgentKnowledgeDoc[]
  runs                      AIAgentRun[]

  @@index([organizationId])
  @@index([organizationId, active])
  @@index([archetype])
  @@map("ai_agent_configs")
}

model AIAgentKnowledgeDoc {
  id             String                  @id @default(cuid())
  organizationId String
  agentId        String
  title          String
  source         String                  @default("upload")
  mimeType       String?
  sizeBytes      Int                     @default(0)
  storageUrl     String?
  status         AIAgentKnowledgeStatus  @default(PENDING)
  errorMessage   String?
  chunkCount     Int                     @default(0)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  chunks         AIAgentKnowledgeChunk[]
  agent          AIAgentConfig           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([agentId, status])
  @@map("ai_agent_knowledge_docs")
}

/// NOTA: a coluna `embedding` é criada via SQL cru na migration
/// (`vector(1536)` do pgvector). O Prisma não tem suporte nativo,
/// por isso o campo não aparece aqui — acessamos via `$queryRaw`
/// para inserção e similarity search (operador `<=>`).
model AIAgentKnowledgeChunk {
  id             String              @id @default(cuid())
  organizationId String
  docId          String
  content        String
  /// Offset em caracteres do documento original (para futura UI de
  /// highlighting do trecho citado).
  position       Int                 @default(0)
  tokenCount     Int                 @default(0)
  createdAt      DateTime            @default(now())
  doc            AIAgentKnowledgeDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([docId])
  @@map("ai_agent_knowledge_chunks")
}

/// Cada chamada ao runner (mensagem no inbox, playground ou step
/// de automation) abre um Run. O trace detalhado fica em
/// AIAgentMessage — útil para debug e faturamento.
model AIAgentRun {
  id              String           @id @default(cuid())
  organizationId  String
  agentId         String
  /// Origem do run — "inbox" | "playground" | "automation" | "api".
  source          String           @default("inbox")
  conversationId  String?
  contactId       String?
  /// Resposta final do assistant (truncada para preview). O trace
  /// completo vive em AIAgentMessage.
  responsePreview String?
  inputTokens     Int              @default(0)
  outputTokens    Int              @default(0)
  /// Custo estimado em USD baseado em pricing.ts no momento do run.
  costUsd         Float            @default(0)
  status          AIAgentRunStatus @default(RUNNING)
  errorMessage    String?
  createdAt       DateTime         @default(now())
  finishedAt      DateTime?
  messages        AIAgentMessage[]
  agent           AIAgentConfig    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([agentId, createdAt])
  @@index([conversationId])
  @@index([status])
  @@map("ai_agent_runs")
}

model AIAgentMessage {
  id             String       @id @default(cuid())
  organizationId String
  runId          String
  /// "system" | "user" | "assistant" | "tool".
  role           String
  content        String
  /// Quando role="tool", qual tool foi chamada (ex.: "create_deal").
  toolName       String?
  /// JSON com args (call) ou result (retorno) serializados.
  toolData       Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  run            AIAgentRun   @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([runId, createdAt])
  @@map("ai_agent_messages")
}

/// Mensagem programada para envio futuro em uma conversa. O worker
/// `scheduled-messages-worker` processa entradas com `status = PENDING`
/// e `scheduledAt <= now()`, enviando pelo canal correto. Para canal
/// WhatsApp (Meta), se a sessão de 24h estiver expirada no momento do
/// envio, é usado o template `fallbackTemplateName` (obrigatório se o
/// usuário optou por agendar em canal Meta com risco de expiração).
///
/// Cancelamento automático: sempre que uma nova mensagem chega ou é
/// enviada (inbound ou outbound) na mesma conversa, todos os agendamentos
/// `PENDING` são cancelados com `cancelReason = "client_reply"` ou
/// `"agent_reply"`. Cancelamento manual via UI usa `cancelReason = "manual"`.
model ScheduledMessage {
  id                       String                 @id @default(cuid())
  organizationId           String
  conversationId           String
  /// Quem criou o agendamento.
  createdById              String
  /// Texto livre a ser enviado.
  content                  String
  /// Quando enviar (UTC). Worker checa a cada 30s.
  scheduledAt              DateTime
  /// Anexo opcional (mantém o mesmo padrão das mensagens normais).
  mediaUrl                 String?
  /// Tipo MIME do anexo (ex.: "image/png"). Null se `mediaUrl` null.
  mediaType                String?
  /// Nome original do arquivo (para exibição/ download).
  mediaName                String?
  /// Template oficial da Meta a ser usado como fallback se a sessão de
  /// 24h estiver expirada no momento do envio. Null = envia texto livre
  /// mesmo que expire (canal não-Meta ou usuário escolheu não definir).
  fallbackTemplateName     String?
  /// Variáveis para substituir no template, no formato definido pelo
  /// `TemplatePicker` ({ header: [...], body: [...], buttons: [...] }).
  fallbackTemplateParams   Json?
  /// Locale do template (ex.: "pt_BR", "en_US").
  fallbackTemplateLanguage String?
  status                   ScheduledMessageStatus @default(PENDING)
  /// Preenchido quando status = SENT.
  sentAt                   DateTime?
  /// ID da Message criada pelo worker ao enviar (para auditoria/UI).
  sentMessageId            String?
  /// Preenchido quando status = CANCELLED.
  cancelledAt              DateTime?
  /// User que cancelou manualmente (null quando o cancelamento foi automático).
  cancelledById            String?
  /// "client_reply" | "agent_reply" | "manual" | "conversation_closed".
  cancelReason             String?
  /// Preenchido quando status = FAILED.
  failedAt                 DateTime?
  /// Mensagem técnica do erro (ex.: "Meta session expired and no fallback
  /// template configured").
  failureReason            String?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  cancelledBy              User?                  @relation("ScheduledMessageCancelledBy", fields: [cancelledById], references: [id])
  conversation             Conversation           @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdBy                User                   @relation("ScheduledMessageCreatedBy", fields: [createdById], references: [id])
  organization             Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([conversationId, status])
  @@index([status, scheduledAt])
  @@index([createdById])
  @@map("scheduled_messages")
}

model BulkOperation {
  id             String              @id @default(cuid())
  organizationId String
  /// Tipo da operação — direciona o roteamento no worker para o handler correto.
  type           BulkOperationType
  status         BulkOperationStatus @default(PENDING)
  /// Quantidade total de itens a processar (calculado no enqueue).
  total          Int                 @default(0)
  /// Itens processados (sucesso + falha + ignorados). Atualizado em chunks
  /// pelo worker; cliente calcula `progressPercent = processed/total`.
  processed      Int                 @default(0)
  /// Itens que aplicaram a operação com sucesso (incluindo no-ops idempotentes).
  succeeded      Int                 @default(0)
  /// Itens que falharam — detalhe individual em `errors`.
  failed         Int                 @default(0)
  /// Lista (JSON) de erros por item, formato:
  /// [{ itemId, message, attempt, at }, ...]
  /// Limitado a ~500 entradas pelo worker para evitar bloat em DB; quando
  /// excede o cap, o worker marca `errorsTruncated=true` via metadata.
  errors         Json?
  /// Snapshot do payload de entrada do job (ex.: { dealIds, stageId }).
  /// Usado para auditoria e replay manual. Mantém em sync com o tipo do job.
  payload        Json
  /// User que iniciou a operação. SetNull se o user for deletado/anonimizado
  /// — preserva histórico mesmo após LGPD/erasure.
  createdById    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  /// Quando o worker pegou o job para processar (status -> PROCESSING).
  startedAt      DateTime?
  /// Quando o worker terminou (status -> COMPLETED/PARTIAL/FAILED/CANCELLED).
  finishedAt     DateTime?
  createdBy      User?               @relation("BulkOperationCreatedBy", fields: [createdById], references: [id])
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([organizationId, type, status])
  @@map("bulk_operations")
}

enum OrgStatus {
  /// Operação normal.
  ACTIVE
  /// Suspensa pelo super-admin (inadimplência, abuso, etc). Bloqueia login
  /// de membros e mostra "org suspensa — contate o admin EduIT".
  SUSPENDED
  /// Arquivada — não aparece em listas padrão, dados preservados. Usado
  /// quando o cliente cancela mas queremos manter histórico por N meses.
  ARCHIVED
}

enum SubscriptionStatus {
  /// Em uso normal (paga ou free).
  ACTIVE
  /// Free trial (com data de fim em currentPeriodEnd).
  TRIALING
  /// Stripe nao conseguiu cobrar — tentativas em curso. Acesso continua.
  PAST_DUE
  /// Falha de pagamento confirmada — acesso bloqueado para downgrade.
  UNPAID
  /// Cancelada (sem renovar). Acesso ate currentPeriodEnd, depois free.
  CANCELED
}

