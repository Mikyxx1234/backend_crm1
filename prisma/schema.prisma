generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// Multi-tenancy (Organizations)
// ──────────────────────────────────────────────
// Toda entidade tenant-scoped carrega `organizationId` direto (mesmo
// quando herdaria via FK) para simplificar policies de RLS no Postgres
// e permitir que a Prisma Client Extension injete `where/data` uniforme.
// Super-admins EduIT (User.isSuperAdmin=true) têm `organizationId=null`
// e podem cruzar orgs via painel `/admin` (bypass da RLS).

model Organization {
  id                    String    @id @default(cuid())
  /// Nome comercial exibido no app (cabeçalho, emails, faturamento interno).
  name                  String
  /// Slug URL-friendly único global. Hoje não roteia por subdomínio, mas
  /// o slug já fica reservado pra quando ativarmos `{slug}.crm.eduit.com.br`.
  slug                  String    @unique
  status                OrgStatus @default(ACTIVE)
  industry              String?
  size                  String?
  phone                 String?
  /// URL pública do logo (hoje `/uploads/org-logos/{id}.png`; quando migrar
  /// pra S3/R2 basta apontar pra URL completa).
  logoUrl               String?
  /// Cor principal (hex) aplicada em headers/CTAs do app. Null = default EduIT.
  primaryColor          String?   @default("#1e3a8a")
  /// Preenchido quando o admin terminou o wizard de 6 passos. Enquanto for
  /// null, o layout força redirecionamento pra `/onboarding` após login.
  onboardingCompletedAt DateTime?
  /// User (super-admin EduIT) que criou essa org pelo painel `/admin`.
  /// Null só em migrations (org padrão EduIT) ou quando o user sumiu.
  createdById           String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  users                    User[]
  invites                  OrganizationInvite[]
  contacts                 Contact[]
  contactPhoneChanges      ContactPhoneChange[]
  companies                Company[]
  tags                     Tag[]
  customFields             CustomField[]
  contactCustomFieldValues ContactCustomFieldValue[]
  dealCustomFieldValues    DealCustomFieldValue[]
  productCustomFieldValues ProductCustomFieldValue[]
  pipelines                Pipeline[]
  stages                   Stage[]
  deals                    Deal[]
  dealProducts             DealProduct[]
  dealEvents               DealEvent[]
  activityEvents           ActivityEvent[]
  products                 Product[]
  activities               Activity[]
  notes                    Note[]
  conversations            Conversation[]
  messages                 Message[]
  whatsappCallEvents       WhatsappCallEvent[]
  scheduledWhatsappCalls   ScheduledWhatsappCall[]
  scheduledMessages        ScheduledMessage[]
  bulkOperations           BulkOperation[]
  automations              Automation[]
  automationSteps          AutomationStep[]
  automationLogs           AutomationLog[]
  automationContexts       AutomationContext[]
  metaWebhookEvents        MetaWebhookEvent[]
  channels                 Channel[]
  baileysAuthKeys          BaileysAuthKey[]
  quickReplies             QuickReply[]
  favoriteMessages         FavoriteMessage[]
  messageTemplates         MessageTemplate[]
  whatsappTemplateConfigs  WhatsAppTemplateConfig[]
  whatsappFlowDefinitions  WhatsappFlowDefinition[]
  distributionRules        DistributionRule[]
  distributionMembers      DistributionMember[]
  distributionResponsibles DistributionResponsible[]
  distributionLogs         DistributionLog[]
  distributionPending      DistributionPending[]
  segments                 Segment[]
  campaigns                Campaign[]
  campaignRecipients       CampaignRecipient[]
  lossReasons              LossReason[]
  apiTokens                ApiToken[]
  mobileLayoutConfigs      MobileLayoutConfig[]
  userDashboardLayouts     UserDashboardLayout[]
  fieldLayoutConfigs       FieldLayoutConfig[]
  webPushSubscriptions     WebPushSubscription[]
  agentSchedules           AgentSchedule[]
  agentStatuses            AgentStatus[]
  agentPresenceLogs        AgentPresenceLog[]
  aiAgentConfigs           AIAgentConfig[]
  aiAgentKnowledgeDocs     AIAgentKnowledgeDoc[]
  auditLogs                AuditLog[]
  dataRequests             DataRequest[]
  featureFlags             OrganizationFeatureFlag[]
  subscription             OrganizationSubscription?
  usageRecords             UsageRecord[]
  aiAgentKnowledgeChunks   AIAgentKnowledgeChunk[]
  aiAgentRuns              AIAgentRun[]
  aiAgentMessages          AIAgentMessage[]
  roles                    Role[]
  roleAssignments          UserRoleAssignment[]
  groups                   Group[]
  groupMembers             GroupMember[]
  organizationSettings     OrganizationSetting[]
  savedFilters             SavedFilter[]
  organizationWidgets      OrganizationWidget[]
  orgUnits                 OrgUnit[]
  productOffers            ProductOffer[]
  inventoryPools           InventoryPool[]
  inventoryMovements       InventoryMovement[]
  productShipping          ProductShipping[]
  productPlans             ProductPlan[]
  courseConfigs            CourseConfig[]
  courseClasses            CourseClass[]
  jobOpenings              JobOpening[]
  productStakeholders      ProductStakeholder[]
  // Catálogo por capacidades (aditivo).
  catalogs                 Catalog[]
  catalogCapabilities      CatalogCapability[]
  productCapabilities      ProductCapability[]
  capacitySlots            CapacitySlot[]
  shippingRanges           ShippingRange[]
  stakeholderRules         StakeholderRule[]
  dealLinks                DealLink[]
  emailAccounts            EmailAccount[]
  emails                   Email[]
  emailCustomFolders       EmailCustomFolder[]
  emailRules               EmailRule[]
  sipExtensions            SipExtension[]
  calls                    Call[]
  callEvents               CallEvent[]
  callProviderConfigs      CallProviderConfig[]
  departments              Department[]
  agentPermissions         AgentPermission[]
  quickReplyGroups         QuickReplyGroup[]

  @@index([status])
  @@map("organizations")
}

/// Feature flags por organizacao (PR 5.4).
///
/// Usado pra rollouts graduais (ex.: liberar ai_agent_v2 pra 5 orgs piloto)
/// e pra planos comerciais (basic vs enterprise) sem branchar codigo.
/// Flags nao listadas aqui caem no DEFAULT do helper `isFeatureEnabled`,
/// que e definido em `src/lib/feature-flags.ts`.
model OrganizationFeatureFlag {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Identificador snake_case da flag. Convencao: `<feature>_enabled` ou
  /// `<feature>_v2`. Lista canonica em `src/lib/feature-flags.ts`.
  key            String
  /// Override explicito (true = on, false = off). Quando ausente, cai
  /// no default da flag.
  enabled        Boolean
  /// JSON livre pra valores por flag (ex.: limites, percentuais, listas).
  /// Validado por flag no helper.
  value          Json?
  /// Quem (super-admin) ativou — pra audit trail.
  setById        String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("organization_feature_flags")
}

/// Estado de instalacao dos widgets (extensoes) por organizacao.
///
/// A DEFINICAO de cada widget (nome, descricao, icone, iframeUrl) vive
/// na tabela `Widget` — populada por widgets internos (seed) ou pelo
/// portal de parceiros. Esta tabela guarda apenas o estado por org:
/// instalado/inativo, quem instalou e config futura opcional.
/// Tenant-scoped (ver `SCOPED_MODELS` em `src/lib/prisma.ts`).
model OrganizationWidget {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Slug do widget — referencia logica para `Widget.slug`. Nao usamos
  /// FK Prisma aqui pra manter a tabela tenant-scoped sem joins
  /// cross-org indesejados (Widget e global, OrganizationWidget e
  /// tenant). Backend valida que o slug existe + esta `ONLINE`.
  widgetSlug     String
  /// "ACTIVE" (instalado) | "INACTIVE" (desativado, sem delete fisico).
  status         String       @default("ACTIVE")
  /// userId de quem instalou/reativou por ultimo — audit trail.
  installedById  String?
  /// JSON livre pra configuracao futura por org (ainda nao usado).
  config         Json?
  installedAt    DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, widgetSlug])
  @@index([organizationId])
  @@index([widgetSlug])
  @@map("organization_widgets")
}

/// Conta de parceiro que publica widgets no marketplace.
///
/// Modelo INDEPENDENTE de `User` — parceiros nao sao membros de nenhuma
/// org do CRM. Auth gerenciada pelo `partner_portal_crm1` (Next.js
/// separado, mesmo Postgres). NAO tenant-scoped (sem `organizationId`).
model PartnerAccount {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  /// Hash bcrypt da senha (gerado no portal). Nunca exposto ao CRM.
  passwordHash String
  /// "ACTIVE" (login liberado) | "SUSPENDED" (bloqueado pelo super-admin).
  status       String   @default("ACTIVE")
  widgets      Widget[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("partner_accounts")
}

/// Definicao canonica de um widget (interno ou de parceiro).
///
/// Substitui o catalogo estatico que vivia em `src/lib/widget-catalog.ts`.
/// Widgets internos (`smart_distribution`, `ai_agents`) viraram seed:
/// `ownerType=INTERNAL`, `status=ONLINE`, sem `partnerAccountId` e sem
/// `iframeUrl` (renderizados via rota propria no CRM).
///
/// Widgets de parceiros (`ownerType=PARTNER`) sao criados pelo portal,
/// tem `iframeUrl` obrigatoria e aparecem no `/widgets` do CRM apenas
/// quando `status=ONLINE`. O parceiro controla o toggle ONLINE/OFFLINE.
///
/// NAO tenant-scoped — o catalogo eh GLOBAL (todas as orgs veem os
/// mesmos widgets ONLINE; o que varia eh o estado de instalacao em
/// `OrganizationWidget`).
model Widget {
  id                 String          @id @default(cuid())
  /// snake_case unico. Para internos, e estavel (gravado historicamente
  /// em `OrganizationWidget.widgetSlug`). Para parceiros, o portal
  /// bloqueia prefixos reservados `core_` e `crm_`.
  slug               String          @unique
  name               String
  description        String
  /// Para INTERNAL: chave de icone resolvida no frontend (ex.: "route").
  /// Para PARTNER: URL absoluta do icone (idealmente PNG/SVG, <100KB).
  icon               String
  category           String
  /// Lista curta de bullet points exibidos no card. Opcional para
  /// parceiros — se vazio, o card renderiza so descricao.
  features           String[]        @default([])
  /// Origem do widget.
  ownerType          WidgetOwnerType
  /// FK pra `PartnerAccount` — NULL quando `ownerType=INTERNAL`.
  partnerAccountId   String?
  partnerAccount     PartnerAccount? @relation(fields: [partnerAccountId], references: [id], onDelete: Cascade)
  /// URL do app do parceiro (iframe). NULL para INTERNAL (renderizado
  /// pela rota propria no CRM).
  iframeUrl          String?
  /// Disponibilidade visual no card ("available" | "coming_soon").
  /// Independente de `status` — um widget pode estar ONLINE mas
  /// "coming_soon" (visivel no card, sem botao instalar).
  availability       String          @default("available")
  /// "DRAFT" (so o dono ve) | "ONLINE" (no marketplace) | "OFFLINE"
  /// (escondido temporariamente, sem deletar). Parceiro controla
  /// pelo portal; internos ficam sempre ONLINE.
  status             WidgetStatus    @default(DRAFT)
  /// Resultado do ultimo healthcheck rodado pelo portal (HEAD/GET na
  /// `iframeUrl` + check de X-Frame-Options/CSP). Usado pra bloquear
  /// publish ONLINE quando a URL nao carrega ou recusa embed.
  healthcheckOk      Boolean?
  healthcheckAt      DateTime?
  /// Mensagem curta de diagnostico do ultimo healthcheck (ex.:
  /// "HTTP 500", "X-Frame-Options: DENY", "Connection timeout").
  healthcheckMessage String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([status])
  @@index([partnerAccountId])
  @@map("widgets")
}

enum WidgetOwnerType {
  /// Widget interno do CRM (renderizado por rota propria).
  INTERNAL
  /// Widget de parceiro (iframe externo).
  PARTNER
}

enum WidgetStatus {
  /// Rascunho — so o parceiro dono ve no portal. NAO aparece no /widgets.
  DRAFT
  /// Publicado no marketplace — aparece em todas as orgs.
  ONLINE
  /// Despublicado temporariamente — escondido do /widgets sem deletar.
  /// Orgs que ja instalaram mantem o registro mas o card some.
  OFFLINE
}

enum OrgStatus {
  /// Operação normal.
  ACTIVE
  /// Suspensa pelo super-admin (inadimplência, abuso, etc). Bloqueia login
  /// de membros e mostra "org suspensa — contate o admin EduIT".
  SUSPENDED
  /// Arquivada — não aparece em listas padrão, dados preservados. Usado
  /// quando o cliente cancela mas queremos manter histórico por N meses.
  ARCHIVED
}

/// Subscription Stripe da organizacao (PR 6.3).
///
/// Liga 1:1 com customer/subscription no Stripe. Apenas **uma**
/// subscription ativa por org (planos Stripe sao mensais ou anuais
/// e o upgrade/downgrade troca o plan_key in-place).
///
/// Estado refletido por webhook `customer.subscription.*` — fonte de
/// verdade fica no Stripe; este modelo e cache local pra leitura rapida
/// (UI admin, gating de features).
model OrganizationSubscription {
  id                   String             @id @default(cuid())
  organizationId       String             @unique
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Identificador do plano (`free`, `starter`, `pro`, `enterprise`).
  /// Lista canonica em src/lib/billing/plans.ts.
  planKey              String
  /// Status de billing — espelha `stripe.subscription.status` quando
  /// integrado, ou estado interno para self-hosted/free.
  status               SubscriptionStatus @default(ACTIVE)
  /// Customer id no Stripe. Null para plano free ou self-hosted.
  stripeCustomerId     String?            @unique
  /// Subscription id no Stripe. Null para plano free ou self-hosted.
  stripeSubscriptionId String?            @unique
  /// Inicio do periodo de billing atual (espelha Stripe period_start).
  currentPeriodStart   DateTime?
  /// Fim do periodo (espelha Stripe period_end). UI mostra "renova em X".
  currentPeriodEnd     DateTime?
  /// Marcado quando o cliente solicita cancelamento — volta a free no
  /// fim do period_end. Null = sem cancelamento agendado.
  cancelAtPeriodEnd    Boolean            @default(false)
  /// Limites override do plano (Json). Null = usar limites do planKey.
  /// Ex.: cliente enterprise negociou messages_sent=500k em vez de 100k.
  limitsOverride       Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([planKey])
  @@index([status])
  @@map("organization_subscriptions")
}

enum SubscriptionStatus {
  /// Em uso normal (paga ou free).
  ACTIVE
  /// Free trial (com data de fim em currentPeriodEnd).
  TRIALING
  /// Stripe nao conseguiu cobrar — tentativas em curso. Acesso continua.
  PAST_DUE
  /// Falha de pagamento confirmada — acesso bloqueado para downgrade.
  UNPAID
  /// Cancelada (sem renovar). Acesso ate currentPeriodEnd, depois free.
  CANCELED
}

/// Append-only usage tracking (PR 6.3).
///
/// Cada chamada a `recordUsage(orgId, meter, amount)` cria uma row aqui.
/// O agregador (`scripts/billing-sync.ts`) le rows nao-reportadas, soma
/// por (orgId, meter, periodo) e envia ao Stripe via Subscription Item
/// Usage Records — garantindo idempotencia via `idempotencyKey`.
///
/// **Append-only** = nunca update (exceto `reportedAt`). Permite reprocessar
/// e auditar historicamente sem perda de dados.
model UsageRecord {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Chave canonica do meter (`messages_sent`, `ai_tokens`, `storage_bytes`,
  /// `contacts_active`, etc.). Lista em src/lib/billing/meters.ts.
  meter          String
  /// Quantidade consumida no evento. Para tokens, e o numero de tokens.
  /// Para mensagens, geralmente 1 por evento. Para storage, bytes delta.
  amount         BigInt
  /// Quando o consumo aconteceu (na pratica, geralmente `now()`).
  occurredAt     DateTime     @default(now())
  /// Origem (mensagem id, run id, file id) — para audit trail.
  /// Combinado com `meter` da uniqueness pra idempotencia opcional.
  sourceId       String?
  /// Quando enviado pra Stripe via metered usage record. Null = pendente.
  reportedAt     DateTime?
  /// idempotency_key usado no envio Stripe — pra retries seguros.
  reportIdempKey String?
  /// JSON livre pra metadados (ex.: channel, modelo IA, etc.).
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([organizationId, meter, occurredAt])
  @@index([organizationId, reportedAt])
  @@index([meter, reportedAt])
  @@map("usage_records")
}

/// Convites gerados pelo painel `/admin` (admin inicial da nova org) e
/// pelo próprio admin da org (passo 5 do wizard, convidar time). Token
/// único usado em `/onboarding?token=` (admin inicial) ou `/accept-invite?token=`
/// (membro). Expira em 7 dias por padrão.
model OrganizationInvite {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  /// Quando ADMIN, o convite abre o wizard completo `/onboarding`. Quando
  /// MANAGER/MEMBER, abre só `/accept-invite` (criar user + entrar no app).
  role           UserRole     @default(ADMIN)
  token          String       @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  acceptedById   String?
  createdById    String?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([email])
  @@index([expiresAt])
  @@map("organization_invites")
}

// ──────────────────────────────────────────────
// Auth
// ──────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  name           String
  /// Email globalmente único — evita ambiguidade no login (um email
  /// pertence a uma única org). Se um operador precisar estar em várias
  /// orgs, usa emails diferentes (ex.: `fulano+clienteA@empresa.com`).
  email          String   @unique
  /// Senha com hash. Opcional porque usuários com `type = AI` não fazem login.
  hashedPassword String?
  /// Distingue operadores humanos de agentes de IA. Agentes IA são tratados
  /// como "users virtuais" para reaproveitar Distribution, Conversation.assignedToId
  /// e Deal.ownerId sem duplicar schema. A configuração do agente (prompt,
  /// arquétipo, ferramentas, conhecimento) vive em AIAgentConfig (1:1).
  type           UserType @default(HUMAN)
  role           UserRole @default(MEMBER)
  avatarUrl      String?
  /// Telefone do agente (formato livre, usado no cartão de perfil).
  phone          String?
  /// Assinatura pessoal inserida automaticamente nas mensagens enviadas
  /// pelo agente (ex.: "Marcelo · EduIT"). Vazio = usa o nome do usuário.
  signature      String?
  /// Mensagem de finalização de conversa personalizada do agente. Quando
  /// presente, tem precedência sobre a mensagem de finalização
  /// configurada no nível da organização.
  closingMessage String?
  /// Tema visual da bolha enviada no chat (`data-chat-theme` no documento).
  chatTheme      String   @default("azul")

  /// Organização a que o usuário pertence. NULL SOMENTE quando `isSuperAdmin=true`
  /// (equipe EduIT). Qualquer outro user obrigatoriamente tem org. O schema
  /// permite null pra super-admin conseguir existir sem vínculo — validação
  /// adicional fica no app layer (user comum com `organizationId=null` não
  /// deveria passar no login).
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Super-admin da EduIT — acessa `/admin/organizations`, cria/suspende
  /// orgs e pode impersonar (fase 2). Bypassa RLS via GUC `app.is_super_admin`.
  isSuperAdmin   Boolean       @default(false)

  /// MFA TOTP (PR 4.1). Secret base32 encriptado em repouso (KEYRING_SECRET).
  /// `mfaEnabledAt` setado SOMENTE apos o primeiro `verify` valido — nunca
  /// no `setup` (evita lock-out se o usuario abandonar o fluxo). NULL =
  /// MFA desabilitado pra esse user; nao bloqueia login.
  mfaSecret    String?
  mfaEnabledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals                          Deal[]
  activities                     Activity[]
  notes                          Note[]
  assignedLeads                  Contact[]                 @relation("AssignedTo")
  distributionMembers            DistributionMember[]
  distributionResponsibles       DistributionResponsible[]
  schedule                       AgentSchedule?
  agentStatus                    AgentStatus?
  presenceLogs                   AgentPresenceLog[]
  assignedConversations          Conversation[]            @relation("ConversationAssignedTo")
  scheduledWhatsappCallsAssigned ScheduledWhatsappCall[]   @relation("ScheduledWhatsappCallAssignee")
  dealEvents                     DealEvent[]
  activityEvents                 ActivityEvent[]           @relation("ActivityEventActor")
  apiTokens                      ApiToken[]
  campaigns                      Campaign[]
  webPushSubscriptions           WebPushSubscription[]
  aiAgentConfig                  AIAgentConfig?
  aiAgentMessages                Message[]                 @relation("MessageAIAgent")
  scheduledMessagesCreated       ScheduledMessage[]        @relation("ScheduledMessageCreatedBy")
  scheduledMessagesCancelled     ScheduledMessage[]        @relation("ScheduledMessageCancelledBy")
  bulkOperationsCreated          BulkOperation[]           @relation("BulkOperationCreatedBy")
  dashboardLayouts               UserDashboardLayout[]
  fieldLayoutConfigs             FieldLayoutConfig[]
  preferences                    UserPreference?
  mfaBackupCodes                 UserMfaBackupCode[]
  loginAttempts                  LoginAttempt[]
  dataRequests                   DataRequest[]
  roleAssignments                UserRoleAssignment[]
  groupMemberships               GroupMember[]
  savedFilters                   SavedFilter[]             @relation("UserSavedFilters")
  emailAccounts                  EmailAccount[]
  sipExtensions                  SipExtension[]
  erasedAt                       DateTime?
  /// Marca usuario anonimizado pela rotina LGPD (PR 4.3). O registro
  /// nao e deletado pra preservar FKs (AuditLog, mensagens). Apos
  /// erase: name = "Usuario removido", email = "erased+<id>@anon.local",
  /// hashedPassword = NULL, phone/avatarUrl/signature = NULL.
  isErased                       Boolean                   @default(false)
  agentPermission                AgentPermission?
  createdQuickReplies            QuickReply[]     @relation("QuickReplyCreatedBy")
  favoriteMessages               FavoriteMessage[]

  @@index([type])
  @@index([organizationId])
  @@index([organizationId, role])
  @@index([organizationId, type])
  @@index([isSuperAdmin])
  @@map("users")
}

/// Codigos de backup de MFA (PR 4.1). Cada codigo e gerado uma vez,
/// mostrado pra usuario imprimir/salvar e armazenado APENAS como hash
/// (bcrypt). `usedAt` marca consumo — codigo de backup e single-use.
model UserMfaBackupCode {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("user_mfa_backup_codes")
}

/// Preferencias pessoais do usuario (por-usuario, NAO por-organizacao).
///
/// Diferente de OrganizationWidget/UserDashboardLayout, este modelo NAO eh
/// tenant-scoped: a chave eh `userId` e ele NAO entra em SCOPED_MODELS
/// (mesmo padrao de UserMfaBackupCode). Toda query filtra por
/// `session.user.id` na camada de aplicacao.
///
/// `sidebar` guarda { items: [{ key, enabled, order }] } — a DEFINICAO dos
/// itens (titulo, href, icone, locked) vive no catalogo de codigo
/// (`src/lib/sidebar-catalog.ts`), nunca aqui. Campo JSON livre pra evoluir
/// sem migration; validado no runtime.
model UserPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// { items: [{ key, enabled, order }] } — personalizacao da sidebar.
  sidebar   Json?
  /// { blocks: [{ key, enabled, order }] } — layout do dashboard comercial.
  dashboard Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_preferences")
}

/// AuditLog (PR 4.2) — registro central de eventos sensiveis.
///
/// Usado pra: investigacao de incidente, conformidade (LGPD/SOC2),
/// painel /admin de auditoria.
///
/// Categorias `entity` previstas (extensivel via string):
///   - "user"           → MFA, role, password, login (alem de login_attempts)
///   - "channel"        → CRUD, conexao/disconexao Meta
///   - "api_token"      → create, revoke
///   - "organization"   → create, suspend, archive
///   - "data_export"    → LGPD export request (PR 4.3)
///   - "data_erase"     → LGPD erase request (PR 4.3)
///   - "impersonation"  → super-admin assumindo identidade de user (futuro)
///
/// `actorId` NULL = ato do sistema (cron, webhook). `actorIsSuperAdmin`
/// flag pra UI destacar cross-tenant.
///
/// `before` e `after` sao snapshots JSON (so dos campos relevantes pra
/// nao explodir tamanho). Conteudo redactado (passwords, tokens) ANTES
/// de persistir — ver src/lib/audit/redact.ts.
model AuditLog {
  id                String        @id @default(cuid())
  /// NULL apenas para eventos cross-tenant (super-admin). Caso contrario,
  /// sempre presente — mesmo eventos de sistema sao atribuidos a uma org
  /// quando aplicavel (ex.: criacao de canal via worker).
  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Quem fez. NULL = ato de sistema (cron, webhook inbound, automation).
  actorId           String?
  actorEmail        String?
  actorIsSuperAdmin Boolean       @default(false)
  /// Categoria livre — ver lista no header.
  entity            String
  /// PK do recurso afetado. NULL pra eventos sem resource especifico
  /// (ex.: "user.login_success").
  entityId          String?
  /// Acao em snake_case: "create" | "update" | "delete" | "login_success"
  /// | "login_fail" | "mfa_enable" | "mfa_disable" | "role_change" |
  /// "token_revoke" | "channel_connect" | "data_export_request" | etc.
  action            String
  /// Snapshot ANTES (apenas em update/delete). JSON com campos
  /// relevantes; sensiveis ja redactados.
  before            Json?
  /// Snapshot DEPOIS (apenas em create/update). JSON com campos
  /// relevantes; sensiveis ja redactados.
  after             Json?
  /// Metadata livre: { reason, channel, requestId, traceId, ... }.
  metadata          Json?
  ip                String?
  userAgent         String?
  createdAt         DateTime      @default(now())

  @@index([organizationId, createdAt])
  @@index([entity, entityId])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Tentativas de login (PR 4.1) — usado pra lockout exponencial e
/// auditoria de brute-force. Limpeza periodica via job dedicado
/// (>30 dias). Identifica o user por email (string) porque tentativas
/// com email inexistente tambem sao logadas (atacante enumerando).
/// `userId` populado SOMENTE quando o user existe.
model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip        String?
  userAgent String?
  /// `success`: credencial OK + MFA OK (se exigido). `mfa_required` =
  /// senha OK mas precisa MFA na proxima request. Failures: bad_password,
  /// bad_mfa, locked, no_user, db_error.
  outcome   String
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("login_attempts")
}

/// LGPD/GDPR data requests (PR 4.3).
///
/// Rastreia pedidos de _portabilidade_ (EXPORT) e _esquecimento_
/// (ERASE). Status:
///   - PENDING:    pedido criado, aguardando processamento
///   - PROCESSING: worker pegou e esta gerando ZIP / anonimizando
///   - READY:      pronto pra download (apenas EXPORT)
///   - COMPLETED:  ERASE finalizado (sem download)
///   - FAILED:     erro durante processamento — ver `error`
///
/// Para EXPORT: `downloadKey` aponta pra arquivo no storage tenant-
/// scoped (PR 1.3). `expiresAt` = +7 dias do READY — depois disso o
/// arquivo e deletado e o registro fica como COMPLETED sem download.
///
/// Para ERASE: nao gera arquivo. `completedAt` marca quando a
/// anonimizacao foi aplicada. O User original NAO e deletado pra
/// preservar FKs (audit_logs, mensagens, deals); apenas anonimizado
/// (ver `User.isErased` + `User.erasedAt`).
model DataRequest {
  id             String            @id @default(cuid())
  /// Sempre presente — pedido e tenant-scoped (mesmo super-admin
  /// pedindo erase de outro user opera dentro da org dele).
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// User alvo do pedido (geralmente == requester, mas super-admin
  /// pode disparar pra outro user).
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Quem disparou — = userId em self-service, !=  em pedido admin.
  requestedById  String?
  type           DataRequestType
  status         DataRequestStatus @default(PENDING)
  /// Path no storage do ZIP de export. Sempre dentro de
  /// /storage/<orgId>/data-exports/<id>.json (ou .zip).
  /// NULL pra ERASE.
  downloadKey    String?
  /// Bytes do arquivo gerado — usado pro UI mostrar tamanho.
  downloadSize   Int?
  /// Quando o arquivo expira (download soft-deleta).
  expiresAt      DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  /// Mensagem de erro (truncada a 1000 chars). NULL em sucesso.
  error          String?
  /// Hash SHA-256 do arquivo (hex). Permite verificar integridade
  /// no download e prevenir tampering.
  contentHash    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId, createdAt])
  @@index([userId, type, createdAt])
  @@index([status, createdAt])
  @@map("data_requests")
}

enum DataRequestType {
  EXPORT
  ERASE
}

enum DataRequestStatus {
  PENDING
  PROCESSING
  READY
  COMPLETED
  FAILED
}

// ──────────────────────────────────────────────
// Dashboard customizável (estilo Kommo)
// ──────────────────────────────────────────────
// Persiste o layout 2D de widgets do dashboard home. Um usuário pode ter
// múltiplos layouts nomeados ("Meu dia", "War Room", etc.) e marcar um
// como default. Cada layout guarda o grid (posições x/y/w/h por widget),
// a lista de widgets visíveis, filtros e tema. O JSON é validado no
// backend contra um schema zod antes de persistir.
model UserDashboardLayout {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String       @default("Padrão")
  /// Um registro com isDefault=true por usuário; default ao abrir /.
  isDefault      Boolean      @default(false)
  /// Preset de origem ("default" | "comercial" | "atendimento" | "equipe" |
  /// "monitor" | "custom"). Usado pra sinalizar se o layout foi modificado
  /// a partir de um template.
  preset         String       @default("custom")
  /// JSON serializado: { widgets: [{ id, x, y, w, h, minW, minH }], filters, theme }.
  /// Formato livre pra evoluir sem migration — validado no runtime.
  data           Json
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, name])
  @@index([organizationId])
  @@index([userId, isDefault])
  @@map("user_dashboard_layouts")
}

/// Layout de seções e campos para DealWorkspace e Inbox CRM.
/// Um registro por contexto por usuário (override pessoal) OU
/// por contexto por org sem userId (padrão do Admin).
model FieldLayoutConfig {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// NULL = configuração padrão da org (salva por Admin/Manager).
  /// Preenchido = override pessoal do agente.
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// "deal_workspace" | "inbox_crm"
  context        String
  /// JSON livre: SectionConfig[] — seções com ordem, hidden e fields
  sections       Json
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, userId, context])
  @@index([organizationId, context])
  @@map("field_layout_configs")
}

enum UserRole {
  ADMIN
  MANAGER
  MEMBER
}

enum UserType {
  HUMAN
  AI
}

// ──────────────────────────────────────────────
// Authorization (RBAC + ReBAC) — Fase 1 Foundation
// ──────────────────────────────────────────────
//
// Modelo: Role = bundle de permissions atomicas (strings namespaced
// no formato "<resource>:<action>"). Cada org tem 3 presets seedados
// (ADMIN/MANAGER/MEMBER) + custom roles criadas pelo admin. Users
// recebem N roles via UserRoleAssignment; permissions efetivas =
// uniao das permissions de todos os roles do user.
//
// O enum UserRole continua existindo (User.role) como "primary preset"
// pra retrocompatibilidade durante o rollout da Fase 1. Helpers antigos
// (requireAdmin/requireManager) sao re-implementados em cima de
// permissions, mas o enum permanece como label de UI/JWT.
//
// Cache: lib/authz/index.ts faz a uniao em memoria + Redis (TTL 60s),
// invalidado em mutacoes via invalidateAuthzCache(userId).
//
// Catalogo canonico de permissions vive em src/lib/authz/permissions.ts.
// O array Role.permissions e validado contra o catalogo no service layer
// (nao no banco — Postgres array nao tem foreign key pra valores).

/// Bundle de permissions por organizacao. ADMIN/MANAGER/MEMBER sao
/// presets seedados (`isSystem=true`, `systemPreset="ADMIN"|...`); admin
/// pode editar permissions desses presets mas NAO pode renomear nem
/// deletar. Custom roles tem `isSystem=false` e `systemPreset=null`.
model Role {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Nome exibido na UI (ex.: "Administrador", "Supervisor SDR").
  name           String
  /// Descricao opcional pra contextualizar custom roles.
  description    String?
  /// Identifica preset do sistema ("ADMIN" | "MANAGER" | "MEMBER").
  /// Null pra custom roles. Usado pra mapear User.role -> Role default
  /// e pra preservar compat com helpers requireAdmin/requireManager.
  systemPreset   String?
  /// Bloqueia rename/delete via UI/API. Editavel: lista de permissions.
  isSystem       Boolean      @default(false)
  /// Lista de permission keys (ex.: ["pipeline:view","conversation:claim"]).
  /// Catalogo canonico em src/lib/authz/permissions.ts. Validacao da
  /// integridade dos itens fica no service layer.
  permissions    String[]
  /// Ponteiro de origem para grupos personalizados (modelo de heranca
  /// pragmatico): id do Role base do qual este grupo "herda". As permissoes
  /// efetivas continuam em `permissions` (copia); a UI calcula herdado vs
  /// personalizado por diff contra o base. Null = sem origem (presets ou
  /// grupos legados). Integridade validada no service layer (mesma org).
  inheritsFrom   String?
  /// Preferencia de sidebar do papel (JSON): { items: [{ key, enabled, order }] }.
  /// Quando null, o papel nao override o menu e usa o catalogo padrao. A sidebar
  /// efetiva do usuario e' a UNIAO dos sidebarItems de todos os roles atribuidos
  /// (habilitado se qualquer role habilitou; ordem = primeira ocorrencia). Ver
  /// getSidebarPreferences em services/user-preferences.ts.
  sidebarItems   Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  assignments UserRoleAssignment[]

  @@unique([organizationId, name])
  @@unique([organizationId, systemPreset])
  @@index([organizationId])
  @@index([inheritsFrom])
  @@map("roles")
}

/// Atribuicao N:N entre User e Role. Um user pode ter varias roles
/// (ex.: "MANAGER" + "Supervisor SDR custom"); permissions efetivas =
/// uniao. Sempre scoped por organizationId pra defesa em profundidade
/// (RLS + invariante de query).
model UserRoleAssignment {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId         String
  role           Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  /// Quem atribuiu (audit trail). Null = seed automatico ou migration.
  assignedById   String?
  createdAt      DateTime     @default(now())

  @@unique([userId, roleId])
  @@index([organizationId])
  @@index([userId])
  @@index([roleId])
  @@map("user_role_assignments")
}

/// Nivel de escopo de uma acao concedida a um grupo (modelo estilo Kommo).
///   NONE = negado
///   SELF = apenas registros do proprio usuario (responsavel)
///   TEAM = registros da equipe (RESERVADO — sem estrutura de times ainda;
///          nao selecionavel na UI, enforcement futuro)
///   ALL  = todos os registros da organizacao
enum PermissionLevel {
  NONE
  SELF
  TEAM
  ALL
}

/// Grupo de acesso (RBAC por grupo — modelo Kommo). As permissoes vivem no
/// GRUPO; usuarios entram via GroupMember e herdam as regras. ADITIVO ao
/// RBAC de papeis (Role): permissoes efetivas de um user = uniao das
/// permissions dos papeis (booleanas) ∪ permissions dos grupos (scoped).
/// A visibilidade por recurso (own/all) deriva do maior nivel concedido.
model Group {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  /// Acessos extras (toggles do editor de grupo).
  sharedInbox    Boolean      @default(true)
  mediaAccess    Boolean      @default(true)
  /// Rotas de nav visiveis para o grupo (vazio = todas). Menu lateral.
  sidebarRoutes  String[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  members     GroupMember[]
  permissions GroupPermission[]
  stageGrants GroupStageGrant[]
  fieldGrants GroupFieldGrant[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("groups")
}

/// Vinculo N:N entre User e Group. Um user pode estar em varios grupos;
/// permissoes efetivas = uniao (maior nivel vence por resource:action).
model GroupMember {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  groupId        String
  group          Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([groupId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([groupId])
  @@map("group_members")
}

/// Permissao com escopo por acao de um grupo. `resource`/`action` referem o
/// PERMISSION_CATALOG (src/lib/authz/permissions.ts). Ausencia de linha = NONE.
model GroupPermission {
  id             String          @id @default(cuid())
  organizationId String
  groupId        String
  group          Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  resource       String
  action         String
  level          PermissionLevel @default(NONE)

  @@unique([groupId, resource, action])
  @@index([organizationId])
  @@index([groupId])
  @@map("group_permissions")
}

/// Visibilidade por etapa do funil para um grupo (ver/editar deals do stage).
model GroupStageGrant {
  id             String  @id @default(cuid())
  organizationId String
  groupId        String
  group          Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  stageId        String
  canView        Boolean @default(true)
  canEdit        Boolean @default(false)

  @@unique([groupId, stageId])
  @@index([organizationId])
  @@index([groupId])
  @@map("group_stage_grants")
}

/// Permissao por campo (Pro) de um grupo. `entity` = "deal"|"contact"|
/// "company"|"product"; `fieldKey` = chave do campo (ex.: "deal.value").
model GroupFieldGrant {
  id             String  @id @default(cuid())
  organizationId String
  groupId        String
  group          Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  entity         String
  fieldKey       String
  canView        Boolean @default(true)
  canEdit        Boolean @default(true)

  @@unique([groupId, entity, fieldKey])
  @@index([organizationId])
  @@index([groupId])
  @@map("group_field_grants")
}

/// Configs por organizacao (substitui SystemSetting global pra dados
/// tenant-specific). SystemSetting permanece pra configs verdadeiramente
/// globais da plataforma EduIT (limites de planos, kill-switches), mas
/// flags de produto (visibility.*, selfAssign.*, etc.) migram pra ca.
///
/// Bug fix da Fase 1: SystemSetting NAO tem organizationId, entao
/// `selfAssign.MEMBER=false` setado por uma org afetava TODAS as orgs.
/// Aqui o problema some por construcao.
model OrganizationSetting {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Chave namespaced. Ex.: "visibility.MEMBER", "selfAssign.MANAGER",
  /// "permissions.MEMBER.canExportContacts". Convencao: dot-separated
  /// camelCase do dominio mais a chave especifica.
  key            String
  /// Valor sempre como string (caller serializa/parse). Pra JSON, salve
  /// JSON.stringify; pra bool, "true"/"false". Mantemos string aqui pela
  /// portabilidade e pelo padrao ja estabelecido em SystemSetting.
  value          String
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("organization_settings")
}

// ──────────────────────────────────────────────
// Contacts & Companies
// ──────────────────────────────────────────────

model Contact {
  id                     String         @id @default(cuid())
  /// Número sequencial por organização (1, 2, 3...).
  /// Gerenciado no app layer via nextContactNumber() — ver services/contacts.ts.
  /// Sem default no banco; a camada de serviço atribui max+1 com retry em P2002.
  number                 Int
  /// ID no sistema de origem (ex.: Kommo) — reimportação atualiza o mesmo registro.
  /// Unicidade é por organização (cada empresa pode importar Kommos diferentes).
  externalId             String?        @map("external_id")
  name                   String
  email                  String?
  phone                  String?
  avatarUrl              String?
  leadScore              Int            @default(0)
  lifecycleStage         LifecycleStage @default(SUBSCRIBER)
  source                 String?
  /// Tracking de anúncios Click-to-WhatsApp (Meta referral)
  adSourceId             String?        @map("ad_source_id")
  adSourceType           String?        @map("ad_source_type")
  adCtwaClid             String?        @map("ad_ctwa_clid")
  adHeadline             String?        @map("ad_headline")
  /// Resolução do post→ad via Marketing API (quando sourceType=="post").
  /// Preenchido async pelo resolver; status="ok"/"not_found"/"no_access"/"error".
  adResolvedId           String?        @map("ad_resolved_id")
  adResolvedName         String?        @map("ad_resolved_name")
  adResolvedAdsetId      String?        @map("ad_resolved_adset_id")
  adResolvedAdsetName    String?        @map("ad_resolved_adset_name")
  adResolvedCampaignId   String?        @map("ad_resolved_campaign_id")
  adResolvedCampaignName String?        @map("ad_resolved_campaign_name")
  adResolvedAt           DateTime?      @map("ad_resolved_at")
  adResolveStatus        String?        @map("ad_resolve_status")
  adResolveError         String?        @map("ad_resolve_error")
  /// UTMs estruturados extraídos do campo `url_tags` do Ad (Marketing API).
  /// Preenchidos junto da resolução post→ad quando o anúncio define parâmetros de URL.
  adUtmSource            String?        @map("ad_utm_source")
  adUtmMedium            String?        @map("ad_utm_medium")
  adUtmCampaign          String?        @map("ad_utm_campaign")
  adUtmContent           String?        @map("ad_utm_content")
  adUtmTerm              String?        @map("ad_utm_term")
  whatsappJid            String?
  /// Meta WhatsApp business-scoped user ID (BSUID), ex. US.xxx — ver doc Meta / usernames.
  /// Unicidade por org (WABAs diferentes têm espaços de BSUID independentes).
  whatsappBsuid          String?        @map("whatsapp_bsuid")

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id])
  assignedToId String?
  assignedTo   User?    @relation("AssignedTo", fields: [assignedToId], references: [id])

  deals                  Deal[]
  activities             Activity[]
  conversations          Conversation[]
  notes                  Note[]
  tags                   TagOnContact[]
  customFields           ContactCustomFieldValue[]
  automationContexts     AutomationContext[]
  whatsappCallEvents     WhatsappCallEvent[]
  scheduledWhatsappCalls ScheduledWhatsappCall[]
  campaignRecipients     CampaignRecipient[]
  phoneChanges           ContactPhoneChange[]
  activityEvents         ActivityEvent[]
  productStakeholders    ProductStakeholder[]
  emails                 Email[]
  calls                  Call[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, number])
  @@unique([organizationId, externalId])
  @@unique([organizationId, whatsappBsuid])
  @@index([organizationId])
  @@index([organizationId, number])
  @@index([organizationId, email])
  @@index([organizationId, phone])
  @@index([organizationId, whatsappJid])
  @@index([organizationId, lifecycleStage])
  @@index([organizationId, leadScore])
  @@index([organizationId, companyId])
  @@index([organizationId, assignedToId])
  @@index([organizationId, createdAt])
  @@index([organizationId, updatedAt])
  @@index([organizationId, assignedToId, lifecycleStage])
  @@index([organizationId, lifecycleStage, createdAt])
  @@map("contacts")
}

enum LifecycleStage {
  SUBSCRIBER
  LEAD
  MQL
  SQL
  OPPORTUNITY
  CUSTOMER
  EVANGELIST
  OTHER
}

/// Histórico imutável de troca de número do cliente.
///
/// Origem principal: webhook Meta WhatsApp Cloud API dispara um evento
/// `messages[].type = "system"` com `system.type = "user_changed_number"`
/// (ou `customer_identity_changed`) quando o usuário ativa o WhatsApp em
/// um número novo mantendo o mesmo BSUID. O contato preserva todo o
/// histórico (mesma row em `contacts`); este log registra a transição
/// pra (a) auditoria e (b) métricas agregadas (quantos clientes trocam
/// de número por mês, por canal etc).
///
/// `MANUAL` cobre o caso do operador editar o telefone na tela de
/// contato; `IMPORT` cobre reimportações em massa que sobrescrevem
/// telefone via CSV/API externa.
model ContactPhoneChange {
  id                String                   @id @default(cuid())
  organizationId    String
  organization      Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactId         String
  contact           Contact                  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  oldPhone          String?                  @map("old_phone")
  newPhone          String?                  @map("new_phone")
  oldBsuid          String?                  @map("old_bsuid")
  newBsuid          String?                  @map("new_bsuid")
  source            ContactPhoneChangeSource @default(WHATSAPP_SYSTEM)
  /// Texto cru do `system.body` da Meta (ex.: "USER A CHANGED FROM
  /// 5511982063029 TO 5511951624721") — útil pra debug/auditoria.
  rawSystemBody     String?                  @map("raw_system_body")
  /// `wamid` (waMessageId) da Message system relacionada, quando
  /// originada via webhook. Permite cross-reference com a timeline.
  /// `@unique` blinda contra reentrega/race do webhook: mesmo se duas
  /// réplicas do servidor processarem o mesmo evento em paralelo, só um
  /// log persiste (a segunda transação falha com violação de unicidade
  /// e o handler trata como duplicata silenciosa).
  messageExternalId String?                  @unique @map("message_external_id")
  createdAt         DateTime                 @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([contactId])
  @@index([createdAt])
  @@index([source])
  @@index([organizationId, source, createdAt])
  @@map("contact_phone_changes")
}

enum ContactPhoneChangeSource {
  WHATSAPP_SYSTEM
  MANUAL
  IMPORT
}

model Company {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  domain         String?
  industry       String?
  size           String?
  phone          String?
  address        String?
  notes          String?

  /// Auto-relação: grupo econômico (matriz) -> filiais/CNPJs.
  parentId String?
  parent   Company?  @relation("CompanyHierarchy", fields: [parentId], references: [id])
  children Company[] @relation("CompanyHierarchy")

  contacts    Contact[]
  jobOpenings JobOpening[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, name])
  @@index([organizationId, parentId])
  @@map("companies")
}

model Tag {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  color          String         @default("#6366f1")
  contacts       TagOnContact[]
  deals          TagOnDeal[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("tags")
}

model TagOnContact {
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([tagId])
  @@map("tags_on_contacts")
}

model TagOnDeal {
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([dealId, tagId])
  @@index([tagId])
  @@map("tags_on_deals")
}

model CustomField {
  id                   String          @id @default(cuid())
  organizationId       String
  organization         Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                 String
  label                String
  type                 CustomFieldType
  options              String[]
  required             Boolean         @default(false)
  entity               String          @default("contact")
  /// Quando true (entity=contact ou deal), o valor aparece no painel lateral Lead na Inbox.
  showInInboxLeadPanel Boolean         @default(false)
  /// Ordem no painel (menor = mais acima). Nulo = depois dos que têm ordem.
  inboxLeadPanelOrder  Int?
  /// Quando true (apenas entity=deal), o valor aparece no painel do Negócio (DealDetail).
  showInDealPanel      Boolean         @default(false)
  /// Formatação condicional do valor no painel lateral. JSON livre:
  /// HighlightRule[] = [{ op, value?, severity, label? }]. Quando uma regra
  /// casa, o valor é exibido como badge colorido (severity). Resolvido em
  /// `src/lib/highlight.ts`. Null/[] = sem destaque.
  highlightRules       Json?

  values            ContactCustomFieldValue[]
  dealValues        DealCustomFieldValue[]
  productValues     ProductCustomFieldValue[]
  flowFieldMappings WhatsappFlowFieldMapping[]

  @@unique([organizationId, name, entity])
  @@index([organizationId])
  @@index([organizationId, entity])
  @@map("custom_fields")
}

/// Filtros salvos do Kanban e outras listagens. `entityType` separa por
/// contexto (ex.: "kanban_deals"). `filterConfig` é JSON livre — schema
/// validado em runtime pelo serviço; permite evoluir filtros sem migration.
model SavedFilter {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entityType     String       @map("entityType")
  name           String
  filterConfig   Json         @default("{}") @map("filterConfig")
  isDefault      Boolean      @default(false) @map("isDefault")
  isShared       Boolean      @default(false) @map("isShared")
  userId         String?      @map("userId")
  user           User?        @relation("UserSavedFilters", fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now()) @map("createdAt")
  updatedAt      DateTime     @updatedAt @map("updatedAt")

  @@index([organizationId, entityType])
  @@index([userId])
  @@map("saved_filters")
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  MULTI_SELECT
  BOOLEAN
  URL
  EMAIL
  PHONE
}

model ContactCustomFieldValue {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  value          String
  contactId      String
  contact        Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  customFieldId  String
  customField    CustomField  @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([contactId, customFieldId])
  @@index([organizationId])
  @@map("contact_custom_field_values")
}

model DealCustomFieldValue {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  value          String
  dealId         String
  deal           Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  customFieldId  String
  customField    CustomField  @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([dealId, customFieldId])
  @@index([organizationId])
  @@map("deal_custom_field_values")
}

// ──────────────────────────────────────────────
// Pipeline & Deals
// ──────────────────────────────────────────────

model Pipeline {
  id                String             @id @default(cuid())
  organizationId    String
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name              String
  isDefault         Boolean            @default(false)
  stages            Stage[]
  distributionRules DistributionRule[]
  /// Canais cujo inbound roteia para este funil (Channel.defaultPipelineId).
  channels          Channel[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([organizationId])
  @@index([organizationId, isDefault])
  @@map("pipelines")
}

model Stage {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  position       Int
  color          String       @default("#6366f1")
  winProbability Int          @default(0)
  rottingDays    Int          @default(30)
  isIncoming     Boolean      @default(false)
  /// Estágios terminais fixos (estilo Kommo): todo pipeline termina em
  /// "Ganho" (isWon) e "Perdido" (isLost). Mover um deal pra cá fecha o
  /// negócio (Deal.status sincronizado); são protegidos contra delete/reorder.
  isWon          Boolean      @default(false)
  isLost         Boolean      @default(false)

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals      Deal[]

  @@unique([pipelineId, position])
  @@index([organizationId])
  @@map("stages")
}

model Deal {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// ID do lead no sistema de origem (ex.: Kommo) — reimportação atualiza o mesmo negócio.
  /// Unicidade por org (cada empresa importa de Kommos independentes).
  externalId     String?      @map("external_id")
  /// Número sequencial do deal dentro da organização. Antes era autoincrement
  /// global; agora é gerenciado em app layer (serviço deals.createDeal calcula
  /// `max(number) + 1` dentro de uma transação). Postgres sequences não
  /// suportam partição por coluna, então a responsabilidade subiu pro app.
  number         Int
  title          String
  value          Decimal      @default(0) @db.Decimal(12, 2)
  status         DealStatus   @default(OPEN)
  /// Papel no fluxo comercial → operacional (PRD §5). Default COMMERCIAL:
  /// deals existentes são comerciais (zero regressão). Indexado e usado em
  /// filtros/relatórios.
  dealRole       DealRole     @default(COMMERCIAL)
  expectedClose  DateTime?
  lostReason     String?
  position       Int          @default(0)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])
  stageId   String
  stage     Stage    @relation(fields: [stageId], references: [id])
  ownerId   String?
  owner     User?    @relation(fields: [ownerId], references: [id])

  activities     Activity[]
  notes          Note[]
  customFields   DealCustomFieldValue[]
  products       DealProduct[]
  tags           TagOnDeal[]
  events         DealEvent[]
  activityEvents ActivityEvent[]
  // Vínculos tipados entre deals (PRD: fulfillment).
  linksFrom      DealLink[]             @relation("DealLinkFrom")
  linksTo        DealLink[]             @relation("DealLinkTo")
  calls          Call[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?

  @@unique([organizationId, number])
  @@unique([organizationId, externalId])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, stageId])
  @@index([organizationId, contactId])
  @@index([organizationId, ownerId])
  @@index([organizationId, createdAt])
  @@index([organizationId, stageId, status])
  @@index([organizationId, stageId, position])
  @@index([organizationId, contactId, status])
  @@index([organizationId, dealRole])
  @@map("deals")
}

enum DealStatus {
  OPEN
  WON
  LOST
}

// ──────────────────────────────────────────────
// Products & Catalog
// ──────────────────────────────────────────────

model Product {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  sku            String?
  price          Decimal      @default(0) @db.Decimal(12, 2)
  unit           String       @default("un")
  /// Campo legado livre ("PRODUCT" | "SERVICE"). Mantido por compatibilidade;
  /// a tipagem nova de domínio é `kind` (enum). Backfill: type=="SERVICE" -> SERVICE.
  type           String       @default("PRODUCT")
  /// Tipo de domínio multi-tipo (Físico, Serviço, Curso, Vaga). Default PHYSICAL.
  kind           ProductKind  @default(PHYSICAL)
  isActive       Boolean      @default(true)
  /// @deprecated (Catálogo Genérico por Capacidades — Fase 1). Não ler em código novo.
  /// A fonte da verdade de estoque/limite é a capacidade `allocation`
  /// (InventoryPool + InventoryMovement). Este campo permanece apenas para o step
  /// legado `consume_stock`, que será substituído pela Fase 5/6. Não dropar antes
  /// de pós-Fase 7.
  trackStock     Boolean      @default(false) @map("track_stock")
  /// @deprecated — ver `trackStock`. Quantidade só lida pelo step `consume_stock`
  /// legado. Pools novos não usam este campo.
  stock          Decimal      @default(0) @db.Decimal(12, 2)

  /// Catálogo ao qual o produto pertence (PRD: herança catálogo → produto).
  /// Nullable para zero regressão; backfill move produtos legados ao catálogo
  /// default da org.
  catalogId String?
  catalog   Catalog? @relation(fields: [catalogId], references: [id])

  dealProducts     DealProduct[]
  customValues     ProductCustomFieldValue[]
  offers           ProductOffer[]
  inventoryPools   InventoryPool[]
  shipping         ProductShipping?
  plans            ProductPlan[]
  courseConfig     CourseConfig?
  jobOpenings      JobOpening[]
  stakeholders     ProductStakeholder[]
  // Catálogo por capacidades (aditivo).
  capabilities     ProductCapability[]
  capacitySlots    CapacitySlot[]
  stakeholderRules StakeholderRule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([organizationId, name])
  @@index([organizationId, type])
  @@index([organizationId, kind])
  @@index([organizationId, catalogId])
  @@map("products")
}

model ProductCustomFieldValue {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productId      String
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  customFieldId  String
  customField    CustomField  @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  value          String

  @@unique([productId, customFieldId])
  @@index([organizationId])
  @@index([productId])
  @@map("product_custom_field_values")
}

model DealProduct {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dealId         String
  deal           Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  productId      String
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity       Decimal      @default(1) @db.Decimal(12, 2)
  unitPrice      Decimal      @default(0) @db.Decimal(12, 2)
  discount       Decimal      @default(0) @db.Decimal(5, 2)

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([dealId])
  @@index([productId])
  @@map("deal_products")
}

// ──────────────────────────────────────────────
// Produtos multi-tipo (Físico, Serviço, Curso, Vaga)
// Primitivos compartilhados: alocação consumível (ledger) + oferta por unidade.
// Tudo aditivo e multi-tenant. Ver docs/decisoes/org-unit.md.
// ──────────────────────────────────────────────

enum ProductKind {
  PHYSICAL
  SERVICE
  COURSE
  JOB_OPENING
}

enum InventoryConsumeTrigger {
  ON_WON
  BY_AUTOMATION
  MANUAL
}

enum InventoryReason {
  SALE
  RESTOCK
  REVERSAL
  RESERVATION
  RESERVATION_RELEASE
  /// Alias agnóstico do PRD para liberação de reserva (= RESERVATION_RELEASE).
  /// Ambos coexistem; o service de alocação novo emite RELEASE.
  RELEASE
  HIRE
  WITHDRAWAL
  ADJUSTMENT
}

enum ProductPlanInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum CourseMode {
  EAD
  IN_PERSON
  HYBRID
}

enum StakeholderChannel {
  WHATSAPP
  EMAIL
}

enum JobOpeningStatus {
  OPEN
  PAUSED
  FILLED
  CLOSED
}

/// Unidade organizacional do tenant (filial / CNPJ). NÃO confundir com
/// `Company` (conta cliente B2B) nem com `Group` (equipe/RBAC, Fase 3).
/// Decisão registrada em docs/decisoes/org-unit.md.
model OrgUnit {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  legalName      String?
  /// CNPJ (ou outro identificador fiscal). Texto livre, sem validação no schema.
  taxId          String?
  address        String?
  active         Boolean      @default(true)

  /// Auto-relação: matriz -> filiais.
  parentId String?
  parent   OrgUnit?  @relation("OrgUnitHierarchy", fields: [parentId], references: [id])
  children OrgUnit[] @relation("OrgUnitHierarchy")

  offers ProductOffer[]
  pools  InventoryPool[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, parentId])
  @@map("org_units")
}

/// Oferta de um produto por unidade: preço/desconto/condições por filial.
/// Sem offer para a unidade -> vale o preço base do Product.
model ProductOffer {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productId      String
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  orgUnitId      String
  orgUnit        OrgUnit      @relation(fields: [orgUnitId], references: [id], onDelete: Cascade)
  price          Decimal      @default(0) @db.Decimal(12, 2)
  discountPct    Decimal?     @db.Decimal(5, 2)
  conditions     Json?
  active         Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, orgUnitId])
  @@index([organizationId])
  @@index([productId])
  @@index([orgUnitId])
  @@map("product_offers")
}

/// Pool de alocação consumível (estoque = vagas = assentos). Saldo = soma dos
/// movimentos (ledger). `orgUnitId` nulo = pool global do produto.
model InventoryPool {
  id             String                  @id @default(cuid())
  organizationId String
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Opcional: pool de vaga manual pode não ter produto de catálogo.
  productId      String?
  product        Product?                @relation(fields: [productId], references: [id], onDelete: Cascade)
  orgUnitId      String?
  orgUnit        OrgUnit?                @relation(fields: [orgUnitId], references: [id])
  consumeTrigger InventoryConsumeTrigger @default(MANUAL)
  allowNegative  Boolean                 @default(false)

  movements     InventoryMovement[]
  courseClasses CourseClass[]
  jobOpenings   JobOpening[]
  /// Slot de capacidade que usa este pool como lugares (capability scheduling).
  capacitySlot  CapacitySlot?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([productId])
  @@index([orgUnitId])
  @@map("inventory_pools")
}

/// Movimento do ledger. `delta` negativo consome; saldo do pool = sum(delta).
/// Reserva = movimentos RESERVATION em aberto (par com RESERVATION_RELEASE/consumo).
model InventoryMovement {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  poolId         String
  pool           InventoryPool   @relation(fields: [poolId], references: [id], onDelete: Cascade)
  delta          Int
  reason         InventoryReason
  /// Deal de origem (scalar — sem relation para não acoplar ao model Deal).
  dealId         String?
  actorId        String?
  actorType      String?
  note           String?

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([poolId])
  @@index([poolId, createdAt])
  @@index([dealId])
  @@map("inventory_movements")
}

/// Dados de envio (kind PHYSICAL). v1: registro, sem cálculo de frete.
model ProductShipping {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productId      String          @unique
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  weightGrams    Int?
  dimensions     Json?
  shippingPolicy Json?
  /// Faixas de CEP × valor × prazo (capability shipping).
  ranges         ShippingRange[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@map("product_shipping")
}

/// Plano de recorrência (kind SERVICE). v1: atributo de precificação/MRR.
/// NÃO implementa cobrança/renovação ao cliente final.
model ProductPlan {
  id             String              @id @default(cuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productId      String
  product        Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  name           String
  interval       ProductPlanInterval @default(MONTHLY)
  amount         Decimal             @default(0) @db.Decimal(12, 2)
  active         Boolean             @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([productId])
  @@map("product_plans")
}

/// Configuração de curso (kind COURSE). `postSalePipelineId` (scalar) dispara
/// funil de pós-venda no ganho.
model CourseConfig {
  id                 String       @id @default(cuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productId          String       @unique
  product            Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  mode               CourseMode   @default(EAD)
  postSalePipelineId String?

  classes CourseClass[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@map("course_configs")
}

/// Turma de um curso. Quando presencial, tem um InventoryPool próprio (assentos).
model CourseClass {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  courseConfigId String
  courseConfig   CourseConfig   @relation(fields: [courseConfigId], references: [id], onDelete: Cascade)
  name           String
  startsAt       DateTime?
  endsAt         DateTime?
  location       String?
  poolId         String?
  pool           InventoryPool? @relation(fields: [poolId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([courseConfigId])
  @@map("course_classes")
}

/// Vaga de emprego (kind JOB_OPENING). Alocação = pool de vagas. Funis B2B
/// (venda) e B2C (candidatos) referenciados por scalar id (dropdown).
model JobOpening {
  id                  String           @id @default(cuid())
  organizationId      String
  organization        Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productId           String?
  product             Product?         @relation(fields: [productId], references: [id])
  clientCompanyId     String
  clientCompany       Company          @relation(fields: [clientCompanyId], references: [id])
  title               String
  /// Deal B2B que vendeu a vaga (scalar).
  b2bDealId           String?
  /// Funil B2C de candidatos (scalar).
  candidatePipelineId String?
  poolId              String
  pool                InventoryPool    @relation(fields: [poolId], references: [id])
  /// Estágio do funil B2C que consome a vaga (scalar).
  consumeStageId      String?
  /// Estágio do funil B2C que reserva a vaga (scalar).
  reserveStageId      String?
  status              JobOpeningStatus @default(OPEN)

  stakeholders ProductStakeholder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([clientCompanyId])
  @@index([poolId])
  @@map("job_openings")
}

/// Stakeholder (interessado) de um produto/vaga — sempre um Contact existente.
/// NUNCA campos soltos de email/telefone.
model ProductStakeholder {
  id                String             @id @default(cuid())
  organizationId    String
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productId         String?
  product           Product?           @relation(fields: [productId], references: [id], onDelete: Cascade)
  jobOpeningId      String?
  jobOpening        JobOpening?        @relation(fields: [jobOpeningId], references: [id], onDelete: Cascade)
  contactId         String
  contact           Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  role              String
  notifyOnSend      Boolean            @default(false)
  notifyForFeedback Boolean            @default(false)
  channelPreference StakeholderChannel @default(WHATSAPP)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([productId])
  @@index([jobOpeningId])
  @@index([contactId])
  @@map("product_stakeholders")
}

// ──────────────────────────────────────────────────────────────────
// Catálogo Universal por Capacidades (PRD catalogo-capacidades)
//
// Núcleo agnóstico: Product / Catalog / Capability. Verticais são apenas
// TEMPLATES de dados que LIGAM capacidades — NUNCA enums de tipo.
//
// Coexistência aditiva (decisão 2026-06-13): os models legados de produto
// multi-tipo (ProductKind, CourseConfig, JobOpening, InventoryPool/Movement,
// ProductOffer/Plan/Shipping, ProductStakeholder) continuam intactos. As
// capacidades reusam esses primitivos onde possível:
//   - allocation  -> InventoryPool / InventoryMovement
//   - pricing     -> ProductOffer
//   - recurrence  -> ProductPlan
//   - shipping    -> ProductShipping + ShippingRange (novo, faixas de CEP)
//   - stakeholders-> ProductStakeholder + StakeholderRule (novo)
//   - scheduling  -> CapacitySlot (novo)
//   - fulfillment -> DealLink (novo) + Deal.dealRole
//
// O registro de capacidades (conjunto fechado de 8) vive em CÓDIGO
// (src/lib/capabilities) — não há tabela Capability para evitar fonte dupla
// de verdade. As junctions guardam `capabilityKey` validada pelo registry.
// ──────────────────────────────────────────────────────────────────

/// Papel do deal no fluxo comercial → operacional. Indexado e usado em
/// TODOS os filtros/relatórios desde o início (PRD §9, mitigação de
/// "deal sobrecarregado"). Default COMMERCIAL (zero regressão: deals
/// existentes são comerciais).
enum DealRole {
  COMMERCIAL
  OPERATIONAL
}

/// Tipo de vínculo entre deals (PRD §3 — DealLink tipado, não parentDealId).
/// ORIGINATED: deal operacional originado de um deal comercial ganho.
enum DealLinkType {
  ORIGINATED
  RELATED
}

/// Catálogo de produtos por organização. Agrupa produtos e capacidades
/// padrão (herança catálogo → produto com override pontual, PRD §2.5).
/// `isTemplate` marca catálogos salvos como modelo reutilizável da org.
model Catalog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  /// Catálogo default da org (recebe os produtos legados no backfill).
  isDefault      Boolean      @default(false)
  /// Catálogo salvo como template reutilizável (wizard "salvar como template").
  isTemplate     Boolean      @default(false)
  /// Chave do template de origem (ex.: "store", "saas", "education") quando
  /// criado a partir de um seed. String livre — não cria acoplamento vertical.
  templateKey    String?

  products     Product[]
  capabilities CatalogCapability[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, isDefault])
  @@index([organizationId, isTemplate])
  @@map("catalogs")
}

/// Política de override catálogo → produto (Fase 1 do Catálogo Genérico por
/// Capacidades). Aplicada no backend (não decorativa):
///   LOCKED  — produto herda e não pode alterar. PUT rejeita config divergente.
///   DEFAULT — catálogo sugere; produto pode sobrescrever quando presente.
///   OPEN    — catálogo não impõe; produto configura do zero.
enum OverridePolicy {
  LOCKED
  DEFAULT
  OPEN
}

/// Junction catálogo × capacidade. `capabilityKey` é validada pelo registry
/// de código (src/lib/capabilities); `config` é Json validado pelo Zod da
/// capacidade antes de persistir. Capacidades do catálogo são herdadas
/// pelos produtos, com override em ProductCapability — sujeito a `overridePolicy`.
model CatalogCapability {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  catalogId      String
  catalog        Catalog        @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  /// Chave da capacidade (conjunto fechado, ver CAPABILITY_KEYS). Sem FK —
  /// o registry de código é a fonte da verdade.
  capabilityKey  String
  /// Modo da capacidade dentro do registry (ex.: pricing.one_time | recurring | ...).
  /// Fase 2 valida via discriminated union Zod por modo. Backfill: `default`
  /// substituído pela rotina da migration por modo equivalente ao estado atual.
  mode           String         @default("default")
  /// Config da capacidade, validado pelo Zod do modo correspondente.
  config         Json           @default("{}")
  /// Política aplicada no backend: LOCKED rejeita ProductCapability divergente.
  overridePolicy OverridePolicy @default(DEFAULT)
  enabled        Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([catalogId, capabilityKey])
  @@index([organizationId])
  @@index([catalogId])
  @@map("catalog_capabilities")
}

/// Junction produto × capacidade. Override pontual sobre a capacidade do
/// catálogo (ou ativação extra só no produto). Mesmas regras de validação.
/// Override é rejeitado pelo backend quando `CatalogCapability.overridePolicy = LOCKED`.
model ProductCapability {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productId      String
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  capabilityKey  String
  /// Modo da capacidade no produto. Pode diferir do catálogo se a policy
  /// permitir (DEFAULT/OPEN). Validado por discriminated union Zod (Fase 2).
  mode           String       @default("default")
  /// Override do config no nível do produto. Aplicado em cascata após
  /// CatalogCapability.config — ver helper `resolveCapabilityConfig` (Fase 2).
  config         Json         @default("{}")
  /// Overrides escopados por OrgUnit. Mapa { [orgUnitId]: Partial<Config> }
  /// aplicado por último na cascata: catálogo → produto → unidade.
  unitOverrides  Json?
  enabled        Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, capabilityKey])
  @@index([organizationId])
  @@index([productId])
  @@map("product_capabilities")
}

/// Slot de capacidade (capability `scheduling`): janela reservável com
/// recurso opcional e pool de lugares 1-1 (PRD §4). Substitui CourseClass
/// como caminho agnóstico dali pra frente — sem semântica vertical.
model CapacitySlot {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Produto que oferece o slot (opcional: slot pode ser avulso).
  productId      String?
  product        Product?       @relation(fields: [productId], references: [id], onDelete: Cascade)
  startsAt       DateTime?
  endsAt         DateTime?
  /// Referência livre ao recurso (sala, instrutor, equipamento). Scalar —
  /// sem acoplar a um model de recurso (fora do escopo v1).
  resourceRef    String?
  /// Pool de lugares 1-1 (reusa InventoryPool como AllocationPool). Opcional.
  poolId         String?        @unique
  pool           InventoryPool? @relation(fields: [poolId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([productId])
  @@index([organizationId, startsAt])
  @@map("capacity_slots")
}

/// Faixa de frete (capability `shipping`): faixa de CEP × valor × prazo.
/// Pendura no ProductShipping legado (tabela própria de frete do produto).
model ShippingRange {
  id                String          @id @default(cuid())
  organizationId    String
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productShippingId String
  productShipping   ProductShipping @relation(fields: [productShippingId], references: [id], onDelete: Cascade)
  /// Faixa de CEP (texto livre — formatos variam por país; PRD é global).
  zipFrom           String
  zipTo             String
  price             Decimal         @default(0) @db.Decimal(12, 2)
  /// Prazo de entrega em dias para esta faixa.
  leadDays          Int             @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([productShippingId])
  @@map("shipping_ranges")
}

/// Regra de notificação de stakeholder (capability `stakeholders`):
/// event × role × templateRef. Avaliada por stakeholder-notify em eventos
/// de domínio. Reusa ProductStakeholder como "quem" (Contact × papel).
model StakeholderRule {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Produto ao qual a regra se aplica (opcional: regra pode ser do catálogo).
  productId      String?
  product        Product?           @relation(fields: [productId], references: [id], onDelete: Cascade)
  /// Evento de domínio que dispara (STAGE_ENTERED, DEAL_WON, DEAL_LOST,
  /// ALLOCATION_CONSUMED). String livre alinhada ao enum do registry.
  event          String
  /// Papel do stakeholder alvo (casa com ProductStakeholder.role).
  role           String
  /// Referência ao template/Flow de mensagem (scalar — resolvido em runtime).
  templateRef    String?
  channel        StakeholderChannel @default(WHATSAPP)
  enabled        Boolean            @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([productId])
  @@index([organizationId, event])
  @@map("stakeholder_rules")
}

/// Vínculo tipado entre deals (PRD §3). N:N — um deal comercial pode
/// originar vários operacionais; rastreabilidade "entregue X de N".
model DealLink {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromDealId     String
  fromDeal       Deal         @relation("DealLinkFrom", fields: [fromDealId], references: [id], onDelete: Cascade)
  toDealId       String
  toDeal         Deal         @relation("DealLinkTo", fields: [toDealId], references: [id], onDelete: Cascade)
  linkType       DealLinkType @default(ORIGINATED)

  createdAt DateTime @default(now())

  @@unique([fromDealId, toDealId, linkType])
  @@index([organizationId])
  @@index([fromDealId])
  @@index([toDealId])
  @@map("deal_links")
}

// ──────────────────────────────────────────────
// Deal Events (Timeline / Audit Log)
// ──────────────────────────────────────────────

model DealEvent {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dealId         String
  deal           Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  type           String
  meta           Json         @default("{}")
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([dealId, createdAt])
  @@index([userId])
  @@map("deal_events")
}

// ──────────────────────────────────────────────
// Activity Log (feed unificado estilo Kommo)
// ──────────────────────────────────────────────

model ActivityEvent {
  // PK composta (id, occurredAt): exigência do particionamento por RANGE
  // em occurredAt (Postgres requer a chave de partição em toda PK/UNIQUE).
  // Ver migration 20260606170000_partition_activity_events. O código só
  // faz create()/findMany() — nenhum findUnique por id isolado — então a
  // aridade composta da PK não afeta os call sites.
  id             String   @default(cuid())
  organizationId String
  occurredAt     DateTime @default(now())

  /// Tipo do evento. String livre (sem enum) pra suportar adicao de
  /// novos tipos sem migration — convencao SCREAMING_SNAKE_CASE
  /// (ex.: STAGE_CHANGED, MESSAGE_SENT, FIELD_CHANGED, OWNER_CHANGED,
  /// CONTACT_CREATED, CONVERSATION_CLOSED, TAG_ADDED, NOTE_ADDED,
  /// ACTIVITY_COMPLETED, AUTOMATION_EXECUTED, AI_AGENT_ACTION).
  type String

  // ── Sujeito (entidade que sofreu a acao) ─────────────────────────
  entityType  EventEntityType
  entityId    String
  /// Snapshot textual do sujeito (titulo do lead, nome do contato,
  /// codigo da conversa, etc.). Imutavel — preserva o rotulo na hora
  /// do evento, evita join custoso na listagem do feed.
  entityLabel String?

  // FKs opcionais para escopo secundario / filtros rapidos. Quando
  // um evento toca multiplas entidades (ex.: mensagem num deal aberto
  // do contato), todas relevantes sao preenchidas.
  dealId         String?
  contactId      String?
  conversationId String?

  // ── Ator (quem fez) ──────────────────────────────────────────────
  actorType     ActorType
  actorUserId   String?
  actorLabel    String?
  actorSublabel String?
  actorRef      String?

  // ── Conteudo (old/new + meta livre) ──────────────────────────────
  /// Identificador do campo alterado (ex.: "stage", "status", "owner",
  /// "title", "value", "lostReason", ou label do custom field).
  field    String?
  oldValue String?
  newValue String?
  /// JSON livre para detalhes adicionais (preview de mensagem, IDs
  /// auxiliares, payload do step de automacao, etc.).
  meta     Json    @default("{}")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser    User?         @relation("ActivityEventActor", fields: [actorUserId], references: [id])
  deal         Deal?         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact      Contact?      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@id([id, occurredAt])
  @@index([organizationId, occurredAt(sort: Desc)])
  @@index([organizationId, entityType, entityId, occurredAt(sort: Desc)])
  @@index([organizationId, dealId, occurredAt(sort: Desc)])
  @@index([organizationId, contactId, occurredAt(sort: Desc)])
  @@index([organizationId, conversationId, occurredAt(sort: Desc)])
  @@index([organizationId, actorUserId, occurredAt(sort: Desc)])
  @@index([organizationId, type, occurredAt(sort: Desc)])
  @@index([organizationId, actorType, occurredAt(sort: Desc)])
  @@map("activity_events")
}

/// HUMAN       : operador humano logado (sessao web ou app)
/// AI          : agente de IA (User com type=AI)
/// AUTOMATION  : automacao/bot do CRM ("SalesBot" etc.) — userId pode ser null
/// INTEGRATION : integracao externa via Bearer token (n8n, webhook autenticado)
/// SYSTEM      : sistema/cron/webhook sem ator identificavel
enum ActorType {
  HUMAN
  AI
  AUTOMATION
  INTEGRATION
  SYSTEM
}

/// Tipo de entidade-sujeito do evento. Aberto pra extensao (novos tipos
/// exigem migration porque eh enum Postgres — alternativa seria String,
/// mas com enum o feed UI ganha exhaustiveness checking).
enum EventEntityType {
  DEAL
  CONTACT
  CONVERSATION
  MESSAGE
  ACTIVITY
  NOTE
  TAG
  PIPELINE
  STAGE
  AUTOMATION
  /// Catálogo por capacidades: alertas/eventos de produto/pool sem deal.
  PRODUCT
}

// ──────────────────────────────────────────────
// Activities & Notes
// ──────────────────────────────────────────────

model Activity {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           ActivityType
  title          String
  description    String?
  completed      Boolean      @default(false)
  scheduledAt    DateTime?
  completedAt    DateTime?

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, scheduledAt])
  @@index([organizationId, userId])
  @@index([organizationId, completed, scheduledAt])
  @@index([contactId])
  @@index([dealId])
  @@index([dealId, scheduledAt])
  @@map("activities")
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  TASK
  NOTE
  WHATSAPP
  OTHER
}

model Note {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  content        String
  contactId      String?
  contact        Contact?     @relation(fields: [contactId], references: [id])
  dealId         String?
  deal           Deal?        @relation(fields: [dealId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([contactId])
  @@index([dealId])
  @@index([userId])
  @@index([dealId, createdAt])
  @@index([contactId, createdAt])
  @@map("notes")
}

// ──────────────────────────────────────────────
// Conversations & Messages
// ──────────────────────────────────────────────

model Conversation {
  id                   String             @id @default(cuid())
  organizationId       String
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// ID externo (ex.: Meta thread id) — unicidade por organização.
  externalId           String?
  channel              String
  status               ConversationStatus @default(OPEN)
  inboxName            String?
  unreadCount          Int                @default(0)
  lastReadAt           DateTime?
  lastInboundAt        DateTime?
  lastMessageDirection String?
  hasAgentReply        Boolean            @default(false)
  hasError             Boolean            @default(false)
  pinnedNoteId         String?
  /// Mensagem fixada no topo da conversa (banner estilo WhatsApp).
  /// Diferente de `pinnedNoteId` (exclusivo para notas internas na aba
  /// "Notas") — este campo aceita QUALQUER mensagem (in/out/nota) e é
  /// exibido no topo da timeline de "Conversa". Um único slot por
  /// conversa (fixar outra substitui a anterior — igual WhatsApp).
  pinnedMessageId      String?
  /// Timestamp da saudação disparada pelo agente IA na atribuição
  /// ATUAL. Null quando o agente IA ainda não cumprimentou nesta
  /// atribuição (ou quando a conversa acabou de ser reatribuída).
  /// Usado pra garantir que a saudação dispare em cada novo ciclo
  /// de atribuição ao agente, e não apenas na 1ª vida da conversa.
  aiGreetedAt          DateTime?

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  channelId  String?
  channelRef Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  /// JID original do WhatsApp (phone@s.whatsapp.net ou lid@lid) — usado para envio via Baileys.
  waJid String?

  /// Agente responsável pela conversa na inbox (null = ainda na fila / visível conforme regra de contato).
  assignedToId String?
  assignedTo   User?   @relation("ConversationAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  messages               Message[]
  whatsappCallEvents     WhatsappCallEvent[]
  scheduledWhatsappCalls ScheduledWhatsappCall[]
  scheduledMessages      ScheduledMessage[]
  activityEvents         ActivityEvent[]

  whatsappCallConsentStatus    WhatsappCallConsentStatus @default(NONE)
  whatsappCallConsentUpdatedAt DateTime?
  /// Tipo do opt-in quando `status = GRANTED`. Temporária → vale 7 dias a
  /// partir de `whatsappCallConsentUpdatedAt`. Permanente → vale até o cliente
  /// revogar manualmente no app (ou bloquear a empresa). Null para NONE/REQUESTED/EXPIRED.
  whatsappCallConsentType      WhatsappCallConsentType?
  /// Quando `whatsappCallConsentExpiresAt` não é null, o frontend faz countdown
  /// a partir deste timestamp em vez de calcular a partir de `updatedAt + 7d`.
  /// Null para permanente / não granted.
  whatsappCallConsentExpiresAt DateTime?

  closedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, externalId])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, status, updatedAt])
  @@index([organizationId, contactId])
  @@index([organizationId, assignedToId])
  @@index([organizationId, channelId])
  @@index([contactId, updatedAt])
  @@index([contactId, status])
  @@index([hasError])
  @@index([lastMessageDirection, hasAgentReply])
  @@index([whatsappCallConsentStatus])
  @@map("conversations")
}

/// Eventos da WhatsApp Cloud API Calling (webhook field `calls`).
/// Ref: https://developers.facebook.com/docs/whatsapp/cloud-api/calling
model WhatsappCallEvent {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  metaCallId      String
  phoneNumberId   String
  direction       String
  /// connect | terminate | signaling (RINGING/ACCEPTED/REJECTED via statuses)
  eventKind       String
  signalingStatus String?
  terminateStatus String?
  fromWa          String?
  toWa            String?
  durationSec     Int?
  startTime       DateTime?
  endTime         DateTime?
  bizOpaque       String?
  errorsJson      Json?

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  contactId      String?
  contact        Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([metaCallId])
  @@index([conversationId, createdAt])
  @@index([contactId, createdAt])
  @@index([createdAt])
  @@map("whatsapp_call_events")
}

model Message {
  id               String                  @id @default(cuid())
  organizationId   String
  organization     Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversationId   String
  conversation     Conversation            @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  content          String
  direction        String
  messageType      String                  @default("text")
  /// Distingue quem autorou a mensagem: agente humano, automação/bot ou evento de sistema.
  /// Usado no dashboard de supervisão (/monitor) para separar processamento humano vs automação.
  authorType       MessageAuthorType       @default(human)
  isPrivate        Boolean                 @default(false)
  externalId       String?
  senderName       String?
  /// Quando a mensagem foi gerada por um agente de IA (authorType=bot),
  /// aponta para o User virtual (type=AI). Permite filtrar trace/custo por agente.
  aiAgentUserId    String?
  aiAgentUser      User?                   @relation("MessageAIAgent", fields: [aiAgentUserId], references: [id], onDelete: SetNull)
  mediaUrl         String?
  replyToId        String?
  replyToPreview   String?
  reactions        Json                    @default("[]")
  sendStatus       String                  @default("sent")
  sendError        String?
  /// Token do botão Flow (Cloud API) por envio — correlaciona com webhook de retorno.
  flowToken        String?                 @map("flow_token")
  /// Template config usado no envio outbound (FK). Permite ao webhook
  /// inbound de Flow resolver o `WhatsappFlowDefinition` correto via
  /// `templateConfig.flowId` — sem isso, em organizações com 2+ templates
  /// que disparam Flows o resolver pegava "o último config atualizado"
  /// e gravava as respostas no flow errado (= não preenchia o negócio).
  /// Nullable: mensagens não-template, históricas, ou envios sem
  /// vínculo identificado mantêm NULL.
  templateConfigId String?                 @map("template_config_id")
  templateConfig   WhatsAppTemplateConfig? @relation(fields: [templateConfigId], references: [id], onDelete: SetNull)
  /// Conexão (Channel) por onde ESTA mensagem trafegou. Permite distinguir,
  /// dentro de uma mesma conversa, mensagens recebidas/enviadas por contas
  /// distintas do mesmo tipo de canal (ex.: dois números de WhatsApp da org).
  /// Snapshot no momento da criação. SetNull se o canal for excluído.
  /// Nullable: mensagens históricas (anteriores à feature) ficam sem vínculo.
  channelId        String?
  channelRef       Channel?                @relation(fields: [channelId], references: [id], onDelete: SetNull)
  createdAt        DateTime                @default(now())

  favoritedBy FavoriteMessage[]

  @@index([organizationId])
  @@index([organizationId, createdAt])
  @@index([conversationId, createdAt])
  @@index([conversationId, authorType, createdAt])
  @@index([channelId])
  @@index([externalId])
  @@index([aiAgentUserId, createdAt])
  // Index isolado em createdAt: o relatório /api/reports/messaging
  // filtra mensagens por intervalo de datas em todo o sistema (sem
  // conversationId), e o índice composto acima não é usado nesse caso.
  // Sem este, vira sequential scan na tabela inteira em volumes grandes.
  @@index([createdAt])
  // Resolver de Flow inbound consulta por conversa + flow_token + template
  // — index dedicado evita scan em alta cardinalidade de mensagens.
  @@index([templateConfigId])
  @@map("messages")
}

/// Mensagem favoritada por um agente (marcador pessoal, tipo "salvos" do
/// WhatsApp). Escopo por usuário — cada agente tem sua própria lista,
/// visível apenas pra ele. `@@unique([userId, messageId])` faz o toggle
/// favoritar/desfavoritar ser um upsert/delete idempotente.
model FavoriteMessage {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId      String
  message        Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([userId, messageId])
  @@index([organizationId])
  @@index([messageId])
  @@map("favorite_messages")
}

enum MessageAuthorType {
  human
  bot
  system
}

enum ConversationStatus {
  OPEN
  RESOLVED
  PENDING
  SNOOZED
}

/// Opt-in de chamada de voz (WhatsApp Cloud API / Calling).
/// `DENIED` cobre a recusa explícita pelo cliente (inclui revogar pós-GRANTED).
/// A Meta bloqueia novo pedido por 24h após REJECT.
enum WhatsappCallConsentStatus {
  NONE
  REQUESTED
  GRANTED
  EXPIRED
  DENIED
}

/// Tipo da autorização concedida pelo cliente. A Meta define 2 variantes:
/// - TEMPORARY: "Permitir ligações temporariamente" → 7 dias corridos.
/// - PERMANENT: "Sempre permitir ligações" → vale até revogação manual.
/// Ligações atendidas NÃO estendem o prazo em nenhum dos casos.
enum WhatsappCallConsentType {
  TEMPORARY
  PERMANENT
}

// ──────────────────────────────────────────────
// Automations
// ──────────────────────────────────────────────

model Automation {
  id             String              @id @default(cuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  triggerType    String
  triggerConfig  Json
  active         Boolean             @default(false)
  steps          AutomationStep[]
  contexts       AutomationContext[]
  campaigns      Campaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, active])
  @@index([organizationId, active, triggerType])
  @@map("automations")
}

model AutomationStep {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String
  config         Json
  position       Int
  automationId   String
  automation     Automation   @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([automationId])
  @@index([automationId, position])
  @@map("automation_steps")
}

model AutomationLog {
  id                 String            @id @default(cuid())
  organizationId     String
  organization       Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  automationId       String
  contactId          String?
  dealId             String?
  stepId             String?
  stepType           String?
  status             String
  message            String?
  payload            Json?
  executedAt         DateTime          @default(now())
  metaWebhookEventId String?
  metaWebhookEvent   MetaWebhookEvent? @relation(fields: [metaWebhookEventId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([automationId])
  @@index([contactId])
  @@index([dealId])
  @@index([executedAt])
  @@index([automationId, executedAt])
  @@index([automationId, stepId])
  @@index([metaWebhookEventId])
  @@map("automation_logs")
}

// ──────────────────────────────────────────────
// Meta Webhook Events (auditoria do webhook WhatsApp)
// Guarda o JSON cru completo entregue pela Meta em cada POST,
// junto com identificadores para busca rápida (waMessageId,
// phoneNumberId). 1 evento Meta pode disparar N AutomationLogs.
// Não há limpeza automática — retenção indefinida.
// ──────────────────────────────────────────────

model MetaWebhookEvent {
  id              String        @id @default(cuid())
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  channelId       String?
  channel         Channel?      @relation(fields: [channelId], references: [id], onDelete: SetNull)
  receivedAt      DateTime      @default(now())
  signatureValid  Boolean
  objectType      String?
  eventType       String
  phoneNumberId   String?
  waMessageId     String?
  fromPhone       String?
  rawBody         Json
  headers         Json?
  processed       Boolean       @default(false)
  processingError String?

  automationLogs AutomationLog[]

  @@index([organizationId, receivedAt(sort: Desc)])
  @@index([waMessageId])
  @@index([phoneNumberId, receivedAt(sort: Desc)])
  @@map("meta_webhook_events")
}

// ──────────────────────────────────────────────
// Channels (WhatsApp, Instagram, etc.)
// ──────────────────────────────────────────────

model Channel {
  id                String          @id @default(cuid())
  organizationId    String
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name              String
  type              ChannelType
  provider          ChannelProvider
  status            ChannelStatus   @default(DISCONNECTED)
  config            Json            @default("{}")
  phoneNumber       String?
  lastConnectedAt   DateTime?
  qrCode            String?         @db.Text
  sessionData       Json?
  /// Funil de destino do inbound deste canal. Null = usa o funil padrão da
  /// org (comportamento legado). SetNull ao apagar o funil — o canal volta
  /// ao roteamento padrão em vez de quebrar.
  defaultPipelineId String?
  defaultPipeline   Pipeline?       @relation(fields: [defaultPipelineId], references: [id], onDelete: SetNull)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  conversations     Conversation[]
  messages          Message[]
  baileysAuthKeys   BaileysAuthKey[]
  campaigns         Campaign[]
  metaWebhookEvents MetaWebhookEvent[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, type, status])
  @@index([organizationId, provider, status])
  @@index([defaultPipelineId])
  /// Lookup pelo webhook Meta: `phone_number_id` chega na URL do webhook
  /// antes de haver sessão; usamos este índice pra achar o Channel
  /// (e daí resolver organizationId) em tempo de requisição.
  @@index([phoneNumber])
  @@map("channels")
}

enum ChannelType {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  EMAIL
  WEBCHAT
}

enum ChannelProvider {
  META_CLOUD_API
  BAILEYS_MD
}

enum ChannelStatus {
  CONNECTED
  DISCONNECTED
  CONNECTING
  QR_READY
  FAILED
}

// ──────────────────────────────────────────────
// Baileys Auth State (WhatsApp Multi-Device)
// ──────────────────────────────────────────────

model BaileysAuthKey {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channelId      String
  channel        Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  keyType        String
  keyId          String
  value          Json

  @@unique([channelId, keyType, keyId])
  @@index([organizationId])
  @@index([channelId])
  @@map("baileys_auth_keys")
}

// ──────────────────────────────────────────────
// Quick Replies & Message Templates
// ──────────────────────────────────────────────

model QuickReply {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  content        String
  category       String?
  position       Int          @default(0)
  groupId         String?
  group           QuickReplyGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  attachmentUrl   String?
  createdByUserId String?
  createdBy       User?        @relation("QuickReplyCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([organizationId, category])
  @@index([organizationId, groupId])
  @@map("quick_replies")
}

// ──────────────────────────────────────────────
// Departments
// ──────────────────────────────────────────────

model Department {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  color          String       @default("#6366f1")
  icon           String       @default("🏢")
  businessHoursId String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  conversations    Conversation[]

  @@index([organizationId])
  @@map("departments")
}

// ──────────────────────────────────────────────
// Agent Permissions
// ──────────────────────────────────────────────

model AgentPermission {
  id             String   @id @default(cuid())
  organizationId String
  userId         String   @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  canViewOtherAgentsConversations  Boolean  @default(false)
  disableConversationsWithoutAgent Boolean  @default(false)
  canTransferConversation          Boolean  @default(true)
  canCloseConversation             Boolean  @default(true)
  canDeleteConversation            Boolean  @default(false)
  canManageQuickMessages           Boolean  @default(false)
  canConfigureFieldVisibility      Boolean  @default(false)

  allowedConnectionIds  String[] @default([])
  allowedDepartmentIds  String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@map("agent_permissions")
}

// ──────────────────────────────────────────────
// Quick Reply Groups
// ──────────────────────────────────────────────

model QuickReplyGroup {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  order          Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  quickReplies   QuickReply[]

  @@index([organizationId])
  @@map("quick_reply_groups")
}

model MessageTemplate {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  content        String
  category       String?
  language       String         @default("pt_BR")
  status         TemplateStatus @default(DRAFT)
  channelType    ChannelType?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
  @@map("message_templates")
}

/// Configuração local para cada template WABA (label customizado + liberação para agente).
/// Cada organização tem seus próprios templates Meta; `metaTemplateId` é único
/// apenas dentro de uma org (a Meta gera ids distintos por WABA, mas o id
/// em si não tem prefixo org, então precisa do composite unique).
model WhatsAppTemplateConfig {
  id                String       @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  metaTemplateId    String       @map("meta_template_id")
  metaTemplateName  String       @map("meta_template_name")
  label             String       @default("")
  agentEnabled      Boolean      @default(false) @map("agent_enabled")
  language          String       @default("pt_BR")
  category          String?
  bodyPreview       String       @default("") @map("body_preview")
  /// True se existir secção BUTTONS com pelo menos um botão (FLOW, URL, QUICK_REPLY, …).
  hasButtons        Boolean      @default(false) @map("has_buttons")
  /// Tipos distintos de botão na definição Graph (ex.: FLOW, URL, QUICK_REPLY).
  buttonTypes       String[]     @default([]) @map("button_types")
  /// True se o corpo/cabeçalho tiver placeholders {{…}} ou template NAMED.
  hasVariables      Boolean      @default(false) @map("has_variables")
  /// `flow_action` do primeiro botão FLOW (ex.: NAVIGATE, DATA_EXCHANGE).
  flowAction        String?      @map("flow_action")
  /// `flow_id` do primeiro botão FLOW (string para compatibilidade com Graph).
  flowId            String?      @map("flow_id")
  /// Variáveis do corpo/cabeçalho que o operador preenche no envio (ex.: [{"key":"1","label":"Dia"}]).
  operatorVariables Json?        @map("operator_variables")
  /// Mensagens outbound enviadas com este template — relação inversa
  /// usada pelo resolver de Flow inbound para identificar o flow correto.
  messages          Message[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([organizationId, metaTemplateId])
  @@index([organizationId])
  @@index([organizationId, agentEnabled])
  @@map("whatsapp_template_configs")
}

/// Fluxo WhatsApp (Flow JSON) desenhado no CRM e publicado na WABA.
model WhatsappFlowDefinition {
  id               String               @id @default(cuid())
  /// ID curto para URL (8 chars base64url). Gerado na criação; nulo em registros legados.
  shortId          String?              @unique @map("short_id")
  organizationId   String
  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name             String
  status           WhatsappFlowStatus   @default(DRAFT)
  /// ID Graph retornado por POST /{waba-id}/flows após publicação.
  metaFlowId       String?              @map("meta_flow_id")
  /// Categoria Meta exigida na criação (ex.: LEAD_GENERATION).
  flowCategory     String               @default("LEAD_GENERATION") @map("flow_category")
  /// Versão do gerador CRM (para migrações de formato).
  generatorVersion String               @default("1") @map("generator_version")
  /// json_version devolvido pela Meta após publicar (se disponível).
  metaJsonVersion  String?              @map("meta_json_version")
  publishedAt      DateTime?            @map("published_at")
  screens          WhatsappFlowScreen[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
  @@map("whatsapp_flow_definitions")
}

model WhatsappFlowScreen {
  id        String                 @id @default(cuid())
  flowId    String                 @map("flow_id")
  flow      WhatsappFlowDefinition @relation(fields: [flowId], references: [id], onDelete: Cascade)
  sortOrder Int                    @default(0) @map("sort_order")
  title     String
  fields    WhatsappFlowField[]

  @@index([flowId])
  @@map("whatsapp_flow_screens")
}

model WhatsappFlowField {
  id        String                    @id @default(cuid())
  screenId  String                    @map("screen_id")
  screen    WhatsappFlowScreen        @relation(fields: [screenId], references: [id], onDelete: Cascade)
  /// Slug estável usado como `name` no TextInput Meta (`${form.fieldKey}`).
  fieldKey  String                    @map("field_key")
  label     String
  /// TEXT | EMAIL | PHONE | TEXTAREA | DROPDOWN | RADIO | MULTI_SELECT | DATE
  fieldType String                    @default("TEXT") @map("field_type")
  /// Opções exibidas em Dropdown / RadioButtonsGroup / CheckboxGroup.
  options   String[]                  @default([])
  required  Boolean                   @default(false)
  sortOrder Int                       @default(0) @map("sort_order")
  mapping   WhatsappFlowFieldMapping?

  @@unique([screenId, fieldKey])
  @@index([screenId])
  @@map("whatsapp_flow_fields")
}

model WhatsappFlowFieldMapping {
  id            String                     @id @default(cuid())
  fieldId       String                     @unique @map("field_id")
  field         WhatsappFlowField          @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  targetKind    FlowFieldMappingTargetKind @map("target_kind")
  /// CONTACT_NATIVE: name | phone | email | source — DEAL_NATIVE: title | value | expectedClose
  nativeKey     String?                    @map("native_key")
  customFieldId String?                    @map("custom_field_id")
  customField   CustomField?               @relation(fields: [customFieldId], references: [id], onDelete: SetNull)

  @@index([customFieldId])
  @@map("whatsapp_flow_field_mappings")
}

enum WhatsappFlowStatus {
  DRAFT
  PUBLISHED
  DEPRECATED
}

enum FlowFieldMappingTargetKind {
  CONTACT_NATIVE
  DEAL_NATIVE
  CUSTOM_FIELD
}

enum TemplateStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

// ── Lead Distribution ─────────────────────────────

model DistributionRule {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  mode           DistributionMode     @default(ROUND_ROBIN)
  pipelineId     String?
  pipeline       Pipeline?            @relation(fields: [pipelineId], references: [id], onDelete: SetNull)
  config         Json                 @default("{}")
  isActive       Boolean              @default(true)
  lastIndex      Int                  @default(0)
  members        DistributionMember[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([organizationId])
  @@index([organizationId, isActive])
  @@map("distribution_rules")
}

model DistributionMember {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ruleId         String
  rule           DistributionRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ruleId, userId])
  @@index([organizationId])
  @@map("distribution_members")
}

enum DistributionMode {
  ROUND_ROBIN
  RULE_BASED
  MANUAL
}

/// Responsavel do motor novo de distribuicao (widget `smart_distribution`).
/// Modelo FLAT por usuario. Distingue estado ADMINISTRATIVO (`participates`)
/// de estados OPERACIONAIS (online via AgentStatus, pausa via `paused`/AWAY,
/// expediente via AgentSchedule). Nao substitui DistributionRule/Member ainda.
model DistributionResponsible {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Estado administrativo: false = INATIVO (bloqueado pelo admin).
  participates    Boolean      @default(true)
  /// 0 = SEM limite de fila. >0 bloqueia quando filaAtual >= queueLimit.
  queueLimit      Int          @default(0)
  /// Peso/volume exibido na v2 (default 1). Nao altera a selecao v1.
  volume          Int          @default(1)
  /// Tipo/segmento opcional para compatibilidade de distribuicao.
  type            String?
  /// Pausa temporaria dedicada (alem de AgentStatus.AWAY).
  paused          Boolean      @default(false)
  /// Ultima vez que recebeu lead pelo motor (desempate da selecao).
  lastExecutionAt DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@map("distribution_responsibles")
}

/// Log de execucao do motor de distribuicao (real e por automacao).
/// Simulacao NAO grava aqui. `evaluated` guarda o diagnostico resumido (JSON).
model DistributionLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  triggerSource  String
  dealId         String?
  contactId      String?
  conversationId String?
  selectedUserId String?
  success        Boolean
  reason         String
  evaluated      Json         @default("[]")
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@map("distribution_logs")
}

/// Fila de espera da Distribuicao Inteligente: leads que NAO puderam ser
/// distribuidos porque nenhum responsavel estava elegivel no momento
/// (NO_ELIGIBLE_RESPONSIBLE). Sao redistribuidos automaticamente quando
/// alguem volta a ficar ONLINE (drenagem em retryPendingDistributions).
model DistributionPending {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dealId           String?
  contactId        String?
  conversationId   String?
  distributionType String?
  triggerSource    String
  /// PENDING | RESOLVED | CANCELLED
  status           String       @default("PENDING")
  /// Quantas vezes ja tentamos distribuir este lead.
  attempts         Int          @default(1)
  lastAttemptAt    DateTime     @default(now())
  /// Preenchido quando RESOLVED (responsavel que recebeu).
  resolvedUserId   String?
  resolvedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([organizationId, status])
  @@map("distribution_pending")
}

// ── Automation Context (Salesbot) ─────────────────

model AutomationContext {
  id             String              @id @default(cuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  automationId   String
  automation     Automation          @relation(fields: [automationId], references: [id], onDelete: Cascade)
  contactId      String
  contact        Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  currentStepId  String?
  variables      Json                @default("{}")
  status         AutomationCtxStatus @default(RUNNING)
  timeoutAt      DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([organizationId])
  @@index([automationId, contactId])
  @@index([contactId, status])
  @@index([status, timeoutAt])
  @@map("automation_contexts")
}

enum AutomationCtxStatus {
  RUNNING
  PAUSED
  COMPLETED
  TIMED_OUT
}

// ──────────────────────────────────────────────
// System Settings (key-value)
// ──────────────────────────────────────────────

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

// ──────────────────────────────────────────────
// Agent Schedule & Status
// ──────────────────────────────────────────────

model AgentSchedule {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String       @unique
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  startTime      String       @default("08:00")
  lunchStart     String       @default("12:00")
  lunchEnd       String       @default("13:00")
  endTime        String       @default("18:00")
  timezone       String       @default("America/Sao_Paulo")
  weekdays       Int[]        @default([1, 2, 3, 4, 5])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@map("agent_schedules")
}

model AgentStatus {
  id                     String            @id @default(cuid())
  organizationId         String
  organization           Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId                 String            @unique
  user                   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  status                 AgentOnlineStatus @default(OFFLINE)
  /// Quando true e ONLINE dentro do horário, o agente entra no pool para receber ligações WhatsApp (Calling API).
  availableForVoiceCalls Boolean           @default(false)
  /// Alimentado pelo heartbeat do cliente (POST /api/agents/me/ping).
  /// Usado pelo worker `presence-reaper` para rebaixar status ocioso a AWAY/OFFLINE.
  lastActivityAt         DateTime?
  updatedAt              DateTime          @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([status, lastActivityAt])
  @@map("agent_statuses")
}

/// Histórico de transições de presença do agente. Cada linha representa um "bloco"
/// no estado `status`. Enquanto `endedAt` é NULL, o bloco está em curso.
/// Alimenta o dashboard de Active Time (acumulado por período).
model AgentPresenceLog {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         AgentOnlineStatus
  startedAt      DateTime          @default(now())
  endedAt        DateTime?
  createdAt      DateTime          @default(now())

  @@index([organizationId])
  @@index([userId, startedAt])
  @@index([userId, endedAt])
  @@index([userId, status, startedAt])
  @@map("agent_presence_logs")
}

/// Callback de voz WhatsApp agendado (ex.: após template pós-chamada perdida).
model ScheduledWhatsappCall {
  id               String                      @id @default(cuid())
  organizationId   String
  organization     Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversationId   String
  conversation     Conversation                @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contactId        String
  contact          Contact                     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assigneeUserId   String?
  assignee         User?                       @relation("ScheduledWhatsappCallAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  scheduledAt      DateTime
  status           ScheduledWhatsappCallStatus @default(PENDING)
  notes            String?
  sourceMetaCallId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([conversationId, scheduledAt])
  @@index([assigneeUserId, scheduledAt, status])
  @@index([status, scheduledAt])
  @@map("scheduled_whatsapp_calls")
}

enum ScheduledWhatsappCallStatus {
  PENDING
  DONE
  CANCELLED
}

enum AgentOnlineStatus {
  ONLINE
  OFFLINE
  AWAY
}

// ──────────────────────────────────────────────
// Loss Reasons
// ──────────────────────────────────────────────

model LossReason {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  label          String
  position       Int          @default(0)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([organizationId, isActive, position])
  @@map("loss_reasons")
}

// ──────────────────────────────────────────────
// API Tokens
// ──────────────────────────────────────────────

model ApiToken {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  tokenHash      String       @unique
  tokenPrefix    String
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([tokenHash])
  @@index([userId])
  @@map("api_tokens")
