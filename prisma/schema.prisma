// ──────────────────────────────────────────────
// Campaigns & Segments
// ──────────────────────────────────────────────

model Segment {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  filters        Json
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  campaigns Campaign[]

  @@index([organizationId])
  @@map("segments")
}

model Campaign {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  status         CampaignStatus @default(DRAFT)
  type           CampaignType

  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  segmentId String?
  segment   Segment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  /// Filtros ad-hoc (quando não usa segmento salvo)
  filters   Json?

  /// Tipo TEMPLATE: nome do template Meta
  templateName       String?
  templateLanguage   String? @default("pt_BR")
  templateComponents Json?

  /// Tipo TEXT: conteúdo de texto livre (Baileys)
  textContent String? @db.Text

  /// Tipo AUTOMATION: automação a disparar
  automationId String?
  automation   Automation? @relation(fields: [automationId], references: [id], onDelete: SetNull)

  /// Msgs por segundo (padrão 80 para Meta, 10 para Baileys)
  sendRate    Int       @default(80)
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?

  totalRecipients Int @default(0)
  sentCount       Int @default(0)
  deliveredCount  Int @default(0)
  failedCount     Int @default(0)
  readCount       Int @default(0)
  /// Quantos destinatários responderam (1ª resposta inbound correlacionada).
  /// Não regride o status de entrega — é métrica de engajamento separada.
  repliedCount    Int @default(0)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  recipients CampaignRecipient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([organizationId, scheduledAt])
  @@index([channelId])
  @@index([createdById])
  @@index([status, scheduledAt])
  @@map("campaigns")
}

model CampaignRecipient {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaignId     String
  campaign       Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId      String
  contact        Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  status        RecipientStatus @default(PENDING)
  errorMessage  String?
  metaMessageId String?

  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  /// 1ª resposta inbound do contato correlacionada a este disparo.
  /// Independente de status (entregue/lido). Idempotente: só seta uma vez.
  repliedAt   DateTime?

  createdAt DateTime @default(now())

  @@unique([campaignId, contactId])
  @@index([organizationId])
  @@index([campaignId, status])
  @@index([contactId])
  @@index([contactId, sentAt])
  @@index([metaMessageId])
  @@map("campaign_recipients")
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  PROCESSING
  SENDING
  PAUSED
  COMPLETED
  CANCELLED
  FAILED
}

enum CampaignType {
  TEMPLATE
  TEXT
  AUTOMATION
}

enum RecipientStatus {
  PENDING
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
}

// ──────────────────────────────────────────────
// PWA Mobile Layout (configuracao de UI mobile)
// ──────────────────────────────────────────────

/// Configuracao do layout mobile (PWA) — quais modulos aparecem na
/// bottom nav, ordem, e onde o app abre. Hoje e singleton (uma row
/// global pra organizacao). Quando virarmos multi-tenant, basta
/// trocar `id` por `organizationId` e adicionar a relacao — o
/// codigo do front ja consome via /api/mobile-layout, isolando.
///
/// Decisoes:
///  - `bottomNavModuleIds`: array ordenado, max 5 itens (limite UX
///    pra bottom nav nao quebrar em telas pequenas). O resto cai
///    no MobileMoreSheet automaticamente.
///  - `enabledModuleIds`: subset de TODOS os modulos disponiveis.
///    Modulos fora dessa lista NAO aparecem nem no bottom nav nem
///    no MoreSheet (admin "esconde" features irrelevantes do app).
///  - `startRoute`: rota inicial ao abrir o PWA (default /inbox).
///  - `version`: incrementado a cada save — usado pra cache-bust no
///    front (SWR/React Query refeed).
model MobileLayoutConfig {
  id                 String       @id @default(cuid())
  /// Uma linha por organização (antes era singleton global). `@@unique`
  /// garante que o upsert em `/api/mobile-layout` continue funcionando
  /// sem precisar de lógica extra — chave = organizationId.
  organizationId     String       @unique
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Slugs separados por virgula. Mantemos string em vez de array
  /// pra simplificar serializacao e evitar dependencia de extensoes
  /// Postgres. Ex.: "inbox,pipeline,tasks,contacts,more".
  bottomNavModuleIds String       @default("inbox,pipeline,tasks,contacts")
  /// Slugs separados por virgula. Ex.: "inbox,pipeline,tasks,contacts,companies,settings,profile".
  enabledModuleIds   String       @default("inbox,pipeline,tasks,contacts,companies,settings,profile")
  startRoute         String       @default("/inbox")
  /// Cor de marca opcional (override do navy padrao). Hex.
  /// Quando null, usa o brand-navy global.
  brandColor         String?
  /// Versao incrementada a cada PUT — front faz refetch quando muda.
  version            Int          @default(1)
  updatedAt          DateTime     @updatedAt
  updatedBy          String?

  @@map("mobile_layout_config")
}

// ──────────────────────────────────────────────
// Web Push (PWA notifications)
// ──────────────────────────────────────────────

/// Subscription do Push API (W3C) por dispositivo do operador. Um
/// usuario pode ter N subscriptions (mobile + desktop + outro
/// browser). O `endpoint` e unico globalmente (incluindo a URL de
/// FCM/Mozilla autopush) — fazemos UPSERT por endpoint pra lidar
/// com reinstall de PWA / re-subscription.
model WebPushSubscription {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// URL do push service (FCM, Mozilla autopush, Apple). Unica
  /// globalmente — eh o "ID" da subscription pro browser.
  endpoint       String       @unique
  /// Chave publica P-256 do cliente (base64url). Usada pelo VAPID
  /// pra criptografar o payload.
  p256dh         String
  /// Auth secret (base64url). Tambem usada na criptografia.
  auth           String
  /// User-Agent capturado no momento da subscription — facilita
  /// "esquecer dispositivo X" no UI.
  userAgent      String?
  createdAt      DateTime     @default(now())
  /// Atualizado a cada disparo bem-sucedido. Permite limpar
  /// subscriptions mortas (>30 dias sem entregar).
  lastUsedAt     DateTime?
  /// Marcado quando o push service retorna 410 Gone — guardamos
  /// pra auditoria antes de deletar definitivamente.
  failedAt       DateTime?

  @@index([organizationId])
  @@index([userId])
  @@index([failedAt])
  @@map("web_push_subscriptions")
}

// ──────────────────────────────────────────────
// Meta WhatsApp Pricing Analytics (cache local)
// ──────────────────────────────────────────────
// Cache do endpoint pricing_analytics da Graph API. Sincronizamos
// diariamente (cron) + sob demanda (botao "Sincronizar Meta" no
// /reports). A unica fonte de verdade do CUSTO é a Meta — aqui só
// armazenamos pra evitar bater na Graph a cada page view e pra
// permitir agregaçao/filtro rapido por periodo.
//
// Granularidade: DAILY. Dimensoes: COUNTRY, PHONE, TIER. Cada linha
// é uma combinaçao unica (date, pricingType, pricingCategory,
// country, phoneNumber, tier).
model MetaPricingDailyMetric {
  id              String   @id @default(cuid())
  /// Dia em UTC (00:00:00). Granularity=DAILY na Meta.
  date            DateTime
  /// REGULAR | FREE_CUSTOMER_SERVICE | FREE_ENTRY_POINT | FREE_TIER
  pricingType     String
  /// MARKETING | UTILITY | AUTHENTICATION | SERVICE | AUTHENTICATION_INTERNATIONAL
  pricingCategory String
  /// ISO-2 (BR, US, ...) ou "UNKNOWN" quando a Meta nao retorna.
  country         String   @default("UNKNOWN")
  /// Telefone E.164 (sem '+'). Default '' quando agregado por WABA
  /// (evita NULL distinto no unique composto).
  phoneNumber     String   @default("")
  /// Tier de volume (ex: "TIER_1K", "TIER_10K"). Default '' quando
  /// nao retornado pela Meta.
  tier            String   @default("")
  /// Volume de mensagens nessa combinacao naquele dia.
  volume          Int      @default(0)
  /// Custo em USD (Meta retorna em cents, convertemos antes de salvar).
  cost            Float    @default(0)
  /// Quando esse registro foi atualizado pelo sync. Permite saber
  /// "ultima sincronizacao" no header do relatorio.
  syncedAt        DateTime @default(now()) @updatedAt

  @@unique([date, pricingType, pricingCategory, country, phoneNumber, tier], map: "meta_pricing_unique_combo")
  @@index([date])
  @@index([pricingCategory])
  @@map("meta_pricing_daily_metrics")
}

// ──────────────────────────────────────────────
// AI Agents (operadores virtuais)
// ──────────────────────────────────────────────
// Configuração por agente fica em AIAgentConfig (1:1 com User).
// O User.type=AI é o que aparece em seletores de responsável,
// DistributionMember, Conversation.assignedToId etc. — assim
// reutilizamos toda a infra de atribuição/distribuição.
//
// archetype: template de comportamento que preenche defaults de
//   systemPromptTemplate/enabledTools. Pode ser customizado depois.
// autonomyMode: AUTONOMOUS envia direto ao lead; DRAFT grava como
//   sugestão que o operador humano aprova/edita antes de enviar.
// dailyTokenCap: limite defensivo de custo (0 = sem limite).

model AIAgentConfig {
  id                   String           @id @default(cuid())
  organizationId       String
  organization         Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId               String           @unique
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  archetype            AIAgentArchetype @default(SDR)
  model                String           @default("gpt-4o-mini")
  temperature          Float            @default(0.7)
  maxTokens            Int              @default(1024)
  /// Prompt-template do arquétipo (renderizado em tempo de execução
  /// com variáveis do contato/deal/conversa). Copiado do catálogo
  /// no momento da criação — depois vive por conta própria.
  systemPromptTemplate String           @db.Text
  /// Overrides livres escritos pelo admin (adicionados ao final do
  /// systemPromptTemplate). Ex.: tom específico, regras de produto.
  systemPromptOverride String?          @db.Text
  /// Política dedicada de apresentação de produtos. Injetada no system
  /// prompt apenas quando a tool `search_products` está habilitada.
  /// Dita quais campos do produto priorizar, formato de apresentação,
  /// tom para tratar preço, etc. Formato: texto livre (markdown-like).
  productPolicy        String?          @db.Text
  tone                 String           @default("profissional e cordial")
  language             String           @default("pt-BR")
  autonomyMode         AIAgentAutonomy  @default(DRAFT)
  /// Lista de tool ids habilitadas (ex.: ["create_deal","add_tag","transfer_to_human"]).
  enabledTools         String[]         @default([])
  /// Limite defensivo diário em tokens (input+output). 0 = ilimitado.
  dailyTokenCap        Int              @default(0)
  /// Pipeline preferencial para handoff / criação de deal. Se null,
  /// usa o pipeline default do contato (primeiro pipeline ativo).
  pipelineId           String?
  /// Canal preferencial para envio de mensagens. Null = usa o canal
  /// da conversa em que o agente está respondendo.
  channelId            String?
  active               Boolean          @default(true)

  // ── Piloting (controles operacionais) ─────────────────────
  /// Mensagem de saudação enviada UMA vez por conversa, antes da
  /// primeira resposta do LLM. Null/empty = desativado. Suporta
  /// variáveis simples: {{contact.firstName}}, {{deal.title}}, etc.
  openingMessage String? @db.Text
  /// Delay em ms antes de disparar a saudação (0 = imediato).
  openingDelayMs Int     @default(0)

  /// Timer de inatividade em ms. Quando o agente respondeu por último
  /// e o cliente não respondeu por N ms, dispara o handoff configurado.
  /// 0 = desativado.
  inactivityTimerMs         Int     @default(0)
  /// Modo de handoff: "KEEP_OWNER" (volta pro dono do deal),
  /// "SPECIFIC_USER" (atribui usuário fixo), "UNASSIGN" (deixa na fila).
  inactivityHandoffMode     String  @default("KEEP_OWNER")
  /// Quando mode=SPECIFIC_USER, qual user receber.
  inactivityHandoffUserId   String?
  /// Texto opcional enviado pelo agente antes do handoff.
  inactivityFarewellMessage String? @db.Text

  /// Lista de gatilhos textuais que forçam handoff imediato
  /// (match case-insensitive por substring na mensagem do cliente).
  keywordHandoffs String[] @default([])

  /// Lista de perguntas obrigatórias de qualificação que o agente
  /// deve coletar antes de encerrar/transferir. Formato:
  /// `[{ id, question }, ...]`. Injetado no system prompt.
  qualificationQuestions Json @default("[]")

  /// Configuração de horário de atendimento. Quando `enabled=true` e
  /// o momento atual cai fora do horário, o agente NÃO responde e
  /// envia `offHoursMessage` (ou só registra rascunho se null).
  /// Formato: `{ enabled, timezone, weekdays: [{day,start,end}], offHoursMessage }`.
  businessHours Json?

  /// Estilo de saída: "conversational" (default, proíbe bullets/ficha
  /// técnica) ou "structured" (permite listas/markdown).
  outputStyle String @default("conversational")

  /// Simula comportamento humano: mostra "digitando…" no WhatsApp do
  /// cliente antes de responder e aguarda tempo proporcional ao
  /// tamanho da mensagem. API Meta entrega o indicador por até 25s.
  simulateTyping   Boolean @default(true)
  /// ms por caractere gerado pra calcular o delay de "digitando".
  /// Total = min(1500 + len * perChar, 25000).
  typingPerCharMs  Int     @default(25)
  /// Marca a mensagem recebida como lida (tracinhos azuis) antes de
  /// responder. Se `simulateTyping=true`, a marcação de leitura já
  /// acontece implicitamente na mesma chamada.
  markMessagesRead Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  knowledgeDocs AIAgentKnowledgeDoc[]
  runs          AIAgentRun[]

  @@index([organizationId])
  @@index([organizationId, active])
  @@index([archetype])
  @@map("ai_agent_configs")
}

enum AIAgentArchetype {
  SDR
  ATENDIMENTO
  VENDEDOR
  SUPORTE
}

enum AIAgentAutonomy {
  AUTONOMOUS
  DRAFT
}

model AIAgentKnowledgeDoc {
  id             String                 @id @default(cuid())
  organizationId String
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentId        String
  agent          AIAgentConfig          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  title          String
  source         String                 @default("upload")
  mimeType       String?
  sizeBytes      Int                    @default(0)
  storageUrl     String?
  status         AIAgentKnowledgeStatus @default(PENDING)
  errorMessage   String?
  chunkCount     Int                    @default(0)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  chunks AIAgentKnowledgeChunk[]

  @@index([organizationId])
  @@index([agentId, status])
  @@map("ai_agent_knowledge_docs")
}

enum AIAgentKnowledgeStatus {
  PENDING
  INDEXING
  READY
  FAILED
}

/// NOTA: a coluna `embedding` é criada via SQL cru na migration
/// (`vector(1536)` do pgvector). O Prisma não tem suporte nativo,
/// por isso o campo não aparece aqui — acessamos via `$queryRaw`
/// para inserção e similarity search (operador `<=>`).
model AIAgentKnowledgeChunk {
  id             String              @id @default(cuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  docId          String
  doc            AIAgentKnowledgeDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  content        String              @db.Text
  /// Offset em caracteres do documento original (para futura UI de
  /// highlighting do trecho citado).
  position       Int                 @default(0)
  tokenCount     Int                 @default(0)
  createdAt      DateTime            @default(now())

  @@index([organizationId])
  @@index([docId])
  @@map("ai_agent_knowledge_chunks")
}

/// Cada chamada ao runner (mensagem no inbox, playground ou step
/// de automation) abre um Run. O trace detalhado fica em
/// AIAgentMessage — útil para debug e faturamento.
model AIAgentRun {
  id              String           @id @default(cuid())
  organizationId  String
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentId         String
  agent           AIAgentConfig    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  /// Origem do run — "inbox" | "playground" | "automation" | "api".
  source          String           @default("inbox")
  conversationId  String?
  contactId       String?
  /// Resposta final do assistant (truncada para preview). O trace
  /// completo vive em AIAgentMessage.
  responsePreview String?
  inputTokens     Int              @default(0)
  outputTokens    Int              @default(0)
  /// Custo estimado em USD baseado em pricing.ts no momento do run.
  costUsd         Float            @default(0)
  status          AIAgentRunStatus @default(RUNNING)
  errorMessage    String?
  createdAt       DateTime         @default(now())
  finishedAt      DateTime?

  messages AIAgentMessage[]

  @@index([organizationId])
  @@index([agentId, createdAt])
  @@index([conversationId])
  @@index([status])
  @@map("ai_agent_runs")
}

enum AIAgentRunStatus {
  RUNNING
  COMPLETED
  FAILED
  HANDOFF
}

model AIAgentMessage {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  runId          String
  run            AIAgentRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  /// "system" | "user" | "assistant" | "tool".
  role           String
  content        String       @db.Text
  /// Quando role="tool", qual tool foi chamada (ex.: "create_deal").
  toolName       String?
  /// JSON com args (call) ou result (retorno) serializados.
  toolData       Json?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([runId, createdAt])
  @@map("ai_agent_messages")
}

// ──────────────────────────────────────────────
// Scheduled Messages
// ──────────────────────────────────────────────
/// Mensagem programada para envio futuro em uma conversa. O worker
/// `scheduled-messages-worker` processa entradas com `status = PENDING`
/// e `scheduledAt <= now()`, enviando pelo canal correto. Para canal
/// WhatsApp (Meta), se a sessão de 24h estiver expirada no momento do
/// envio, é usado o template `fallbackTemplateName` (obrigatório se o
/// usuário optou por agendar em canal Meta com risco de expiração).
///
/// Cancelamento automático: sempre que uma nova mensagem chega ou é
/// enviada (inbound ou outbound) na mesma conversa, todos os agendamentos
/// `PENDING` são cancelados com `cancelReason = "client_reply"` ou
/// `"agent_reply"`. Cancelamento manual via UI usa `cancelReason = "manual"`.
model ScheduledMessage {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  /// Quem criou o agendamento.
  createdById String
  createdBy   User   @relation("ScheduledMessageCreatedBy", fields: [createdById], references: [id])

  /// Texto livre a ser enviado.
  content String @db.Text

  /// Quando enviar (UTC). Worker checa a cada 30s.
  scheduledAt DateTime

  /// Anexo opcional (mantém o mesmo padrão das mensagens normais).
  mediaUrl  String?
  /// Tipo MIME do anexo (ex.: "image/png"). Null se `mediaUrl` null.
  mediaType String?
  /// Nome original do arquivo (para exibição/ download).
  mediaName String?

  /// Template oficial da Meta a ser usado como fallback se a sessão de
  /// 24h estiver expirada no momento do envio. Null = envia texto livre
  /// mesmo que expire (canal não-Meta ou usuário escolheu não definir).
  fallbackTemplateName     String?
  /// Variáveis para substituir no template, no formato definido pelo
  /// `TemplatePicker` ({ header: [...], body: [...], buttons: [...] }).
  fallbackTemplateParams   Json?
  /// Locale do template (ex.: "pt_BR", "en_US").
  fallbackTemplateLanguage String?

  status ScheduledMessageStatus @default(PENDING)

  /// Preenchido quando status = SENT.
  sentAt        DateTime?
  /// ID da Message criada pelo worker ao enviar (para auditoria/UI).
  sentMessageId String?

  /// Preenchido quando status = CANCELLED.
  cancelledAt   DateTime?
  /// User que cancelou manualmente (null quando o cancelamento foi automático).
  cancelledById String?
  cancelledBy   User?     @relation("ScheduledMessageCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  /// "client_reply" | "agent_reply" | "manual" | "conversation_closed".
  cancelReason  String?

  /// Preenchido quando status = FAILED.
  failedAt      DateTime?
  /// Mensagem técnica do erro (ex.: "Meta session expired and no fallback
  /// template configured").
  failureReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([conversationId, status])
  @@index([status, scheduledAt])
  @@index([createdById])
  @@map("scheduled_messages")
}

enum ScheduledMessageStatus {
  PENDING
  SENT
  CANCELLED
  FAILED
}

// ──────────────────────────────────────────────
// Bulk Operations (operações em massa assíncronas)
// ──────────────────────────────────────────────
// Registra operações em massa enfileiradas (BullMQ) e processadas por
// workers fora do backend-api. Postgres é a fonte da verdade do
// progresso/histórico — o estado no BullMQ é volátil e existe apenas
// enquanto o job está na fila/processamento.
//
// Escopo inicial: operações sobre Deals (move de stage em lote, update
// em massa de custom fields). O enum `BulkOperationType` é expansível
// para futuras operações pesadas (Contacts, Activities, ETL).
//
// `payload` armazena o JSON de entrada do job (ex.: { dealIds, stageId }),
// usado para auditoria e para reprocessamento manual quando necessário.
// `errors` é JSON com até ~500 entradas { dealId, message, attempt, at }
// — limite proteção contra bloat em operações grandes.

model BulkOperation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// Tipo da operação — direciona o roteamento no worker para o handler correto.
  type   BulkOperationType
  status BulkOperationStatus @default(PENDING)

  /// Quantidade total de itens a processar (calculado no enqueue).
  total     Int @default(0)
  /// Itens processados (sucesso + falha + ignorados). Atualizado em chunks
  /// pelo worker; cliente calcula `progressPercent = processed/total`.
  processed Int @default(0)
  /// Itens que aplicaram a operação com sucesso (incluindo no-ops idempotentes).
  succeeded Int @default(0)
  /// Itens que falharam — detalhe individual em `errors`.
  failed    Int @default(0)

  /// Lista (JSON) de erros por item, formato:
  ///   [{ itemId, message, attempt, at }, ...]
  /// Limitado a ~500 entradas pelo worker para evitar bloat em DB; quando
  /// excede o cap, o worker marca `errorsTruncated=true` via metadata.
  errors  Json?
  /// Snapshot do payload de entrada do job (ex.: { dealIds, stageId }).
  /// Usado para auditoria e replay manual. Mantém em sync com o tipo do job.
  payload Json

  /// User que iniciou a operação. SetNull se o user for deletado/anonimizado
  /// — preserva histórico mesmo após LGPD/erasure.
  createdById String?
  createdBy   User?   @relation("BulkOperationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  /// Quando o worker pegou o job para processar (status -> PROCESSING).
  startedAt  DateTime?
  /// Quando o worker terminou (status -> COMPLETED/PARTIAL/FAILED/CANCELLED).
  finishedAt DateTime?

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([organizationId, type, status])
  @@map("bulk_operations")
}

enum BulkOperationType {
  /// Atualiza custom fields em massa para múltiplos deals (upsert por field).
  DEAL_BULK_UPDATE_FIELDS
  /// Move múltiplos deals para uma mesma stage (idempotente).
  DEAL_BULK_MOVE_STAGE
  /// Reservado — change owner em massa (a portar para async em iteração futura).
  DEAL_BULK_CHANGE_OWNER
  /// Reservado — mark_won/lost/delete em massa.
  DEAL_BULK_MARK_WON
  DEAL_BULK_MARK_LOST
  DEAL_BULK_DELETE
  /// Importação de contatos via arquivo (CSV/XLSX) processada pelo etl-worker.
  CONTACT_IMPORT
}

enum BulkOperationStatus {
  /// Criado no DB, ainda não pego pelo worker.
  PENDING
  /// Worker em execução; `processed` cresce conforme cada chunk completa.
  PROCESSING
  /// Todos os itens processaram com sucesso (failed=0).
  COMPLETED
  /// Worker terminou, mas com falhas pontuais (failed>0, succeeded>0).
  PARTIAL
  /// Worker terminou com erro infraestrutural (todos os itens falharam ou
  /// falha geral antes de processar qualquer item).
  FAILED
  /// Cancelado manualmente (reservado para iteração futura).
  CANCELLED
}

// ──────────────────────────────────────────────
// Módulo de E-mail (IMAP/SMTP multi-conta)
// ──────────────────────────────────────────────

enum EmailEncryption {
  NONE
  SSL_TLS
  STARTTLS
}

enum EmailVisibility {
  SHARED
  PERSONAL
}

enum EmailFolder {
  INBOX
  SENT
  TRASH
}

/// Conta de e-mail conectada (IMAP + SMTP). A senha é armazenada
/// criptografada via AES-256-GCM (`lib/crypto/secrets.ts`). Nunca
/// retorna `passwordEncrypted` em nenhuma resposta de API.
model EmailAccount {
  id             String @id @default(cuid())
  organizationId String

  email             String
  /// Senha criptografada com encryptSecret() (KEYRING_SECRET). Nunca
  /// exposta em respostas de API nem em logs.
  passwordEncrypted String @map("password_encrypted")

  imapHost       String          @map("imap_host")
  imapPort       Int             @map("imap_port")
  imapEncryption EmailEncryption @default(SSL_TLS) @map("imap_encryption")

  smtpHost       String          @map("smtp_host")
  smtpPort       Int             @map("smtp_port")
  smtpEncryption EmailEncryption @default(SSL_TLS) @map("smtp_encryption")

  visibility               EmailVisibility @default(SHARED)
  /// Agrupa mensagens pelo assunto normalizado (sem Re:/Fwd:).
  groupInThreads           Boolean         @default(true) @map("group_in_threads")
  /// Cria contato/lead para remetentes desconhecidos ao responder.
  createContactsForReplies Boolean         @default(false) @map("create_contacts_for_replies")

  /// Proprietário da caixa (relevante quando visibility=PERSONAL).
  ownerUserId String? @map("owner_user_id")
  owner       User?   @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)

  organization  Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  emails        Email[]
  customFolders EmailCustomFolder[]
  rules         EmailRule[]

  createdAt    DateTime  @default(now()) @map("created_at")
  lastSyncedAt DateTime? @map("last_synced_at")

  @@index([organizationId])
  @@index([organizationId, ownerUserId])
  @@map("email_accounts")
}

/// Mensagem de e-mail sincronizada via IMAP ou enviada via SMTP.
/// `(accountId, messageId)` único impede duplicação em re-sync.
model Email {
  id             String @id @default(cuid())
  organizationId String

  accountId String       @map("account_id")
  account   EmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  folder    EmailFolder @default(INBOX)
  /// Agrupa mensagens da mesma conversa. Quando groupInThreads=true,
  /// é o assunto normalizado; caso contrário é o próprio messageId.
  threadId  String      @map("thread_id")
  /// ID único da mensagem no provedor (Message-ID header).
  messageId String      @map("message_id")
  /// UID IMAP da mensagem na pasta (para operações de sync incremental).
  uid       String?

  fromAddress String  @map("from_address")
  fromName    String? @map("from_name")
  toAddress   String  @map("to_address")

  subject  String?
  bodyText String? @map("body_text") @db.Text
  bodyHtml String? @map("body_html") @db.Text

  /// Contato vinculado automaticamente pelo e-mail do remetente.
  contactId String?  @map("contact_id")
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  /// Pasta customizada criada pelo usuário (opcional).
  /// Quando definida, a mensagem aparece na pasta custom em vez da pasta de
  /// sistema (`folder` continua refletindo INBOX/SENT/TRASH).
  customFolderId String?            @map("custom_folder_id")
  customFolder   EmailCustomFolder? @relation(fields: [customFolderId], references: [id], onDelete: SetNull)

  isRead Boolean @default(false) @map("is_read")

  receivedAt DateTime? @map("received_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([accountId, messageId])
  @@index([organizationId])
  @@index([accountId, folder])
  @@index([organizationId, threadId])
  @@index([accountId, isRead])
  @@index([customFolderId])
  @@map("emails")
}

/// Pasta customizada criada pelo usuário em uma conta específica.
/// Mensagens podem ser movidas (manualmente ou por regras) para uma pasta
/// custom. A pasta vive *além* do enum `EmailFolder` — uma mensagem em
/// pasta custom continua tendo `folder` (INBOX/SENT/TRASH) refletindo o
/// estado IMAP.
model EmailCustomFolder {
  id             String       @id @default(cuid())
  organizationId String
  accountId      String       @map("account_id")
  account        EmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  name  String
  color String?

  createdAt DateTime @default(now()) @map("created_at")

  emails Email[]
  rules  EmailRule[]

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([accountId, name])
  @@index([organizationId])
  @@index([accountId])
  @@map("email_custom_folders")
}

/// Regra simples de filtro: condição (campo + contém) + ação (mover ou
/// excluir). Aplicada após persistir cada mensagem nova durante o sync
/// (`email-sync.ts`). Primeira regra que bate vence (ordem por priority).
model EmailRule {
  id             String       @id @default(cuid())
  organizationId String
  accountId      String       @map("account_id")
  account        EmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  name     String
  isActive Boolean @default(true) @map("is_active")

  /// "FROM" | "TO" | "SUBJECT"
  conditionField String @map("condition_field")
  /// Substring buscada (case-insensitive) no campo escolhido.
  conditionValue String @map("condition_value")

  /// "MOVE" | "TRASH"
  action         String             @map("action")
  targetFolderId String?            @map("target_folder_id")
  targetFolder   EmailCustomFolder? @relation(fields: [targetFolderId], references: [id], onDelete: SetNull)

  priority  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([accountId, isActive, priority])
  @@map("email_rules")
}

// ===========================================================================
// Módulo Softphone (SIP/WebRTC) — Fase 1
// ===========================================================================

enum SipExtensionStatus {
  ACTIVE
  INACTIVE
}

/// Estado da máquina de provisionamento automático Api4com.
/// Cada passo concluído persiste o step antes de avançar (retomada segura).
enum TelephonyProvisioningStep {
  IDLE
  CHECK_REMOTE
  CREATE_USER
  CREATE_EXTENSION
  CONFIG_WEBHOOK
  ACTIVE
  FAILED
  DISABLED
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  RINGING
  ANSWERED
  COMPLETED
  MISSED
  BUSY
  FAILED
}

enum WebhookAuthMode {
  HMAC
  TOKEN
}

enum RecordingDelivery {
  URL
  INLINE
  FETCH_LATER
}

/// Ramal SIP de um usuário. Armazena credenciais cifradas para registro
/// via JsSIP no navegador. O backend nunca registra ramal nem processa
/// mídia — só guarda e entrega ao próprio dono autenticado.
model SipExtension {
  id             String @id @default(cuid())
  organizationId String

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  label                 String
  /// Endereço SIP completo — ex.: `ramal@dominio.pbx`.
  sipUri                String @map("sip_uri")
  authUser              String @map("auth_user")
  /// Senha cifrada via encryptSecret() (KEYRING_SECRET). Nunca exposta
  /// fora de /api/sip-extensions/me/credentials (dono autenticado).
  authPasswordEncrypted String @map("auth_password_encrypted")
  /// URL WebSocket do proxy SIP — ex.: `wss://pbx.example.com:8089/ws`.
  wsServer              String @map("ws_server")
  /// Array de URLs STUN — ex.: ["stun:stun.l.google.com:19302"].
  stunServers           Json   @map("stun_servers")
  /// Config TURN opcional — { urls, username, credential }.
  turnServer            Json?  @map("turn_server")
  /// Metadados do provedor (ex.: token Api4Com cifrado). Nunca exposto na API pública.
  providerMeta          Json?  @map("provider_meta")

  status SipExtensionStatus @default(ACTIVE)

  /// ── Provisionamento automático Api4com ─────────────────────────
  /// Toggle principal: indica se o usuário tem telefonia habilitada.
  telephonyEnabled    Boolean                    @default(false) @map("telephony_enabled")
  /// UUID do usuário criado na Api4com via POST /users.
  api4comUserId       String?                    @map("api4com_user_id")
  /// Gateway lógico usado em metadata.gateway (webhookConstraint + /dialer).
  api4comGateway      String?                    @map("api4com_gateway")
  /// Estado da máquina de provisionamento (retomada a partir do último step).
  provisioningStep    TelephonyProvisioningStep  @default(IDLE) @map("provisioning_step")
  /// Último erro para exibição na UI e retomada manual.
  provisioningError   String?                    @map("provisioning_error")
  /// Timestamp de conclusão bem-sucedida do provisionamento.
  provisionedAt       DateTime?                  @map("provisioned_at")

  calls Call[]

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@map("sip_extensions")
}

/// Registro de chamada telefônica. Fonte da verdade = webhook do provedor.
/// Idempotente por (organizationId, provider, providerCallId).
model Call {
  id             String @id @default(cuid())
  organizationId String

  direction CallDirection
  status    CallStatus

  extensionId String?       @map("extension_id")
  extension   SipExtension? @relation(fields: [extensionId], references: [id], onDelete: SetNull)

  provider       String
  providerCallId String @map("provider_call_id")

  fromNumber String @map("from_number")
  toNumber   String @map("to_number")

  contactId String?  @map("contact_id")
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  /// Deal vinculado — preenchido a partir da metadata enviada no /dialer.
  dealId String? @map("deal_id")
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)

  /// Snapshot da metadata Api4com (gateway, crm_user_id, deal_id, contact_id).
  metadata Json?

  startedAt       DateTime? @map("started_at")
  answeredAt      DateTime? @map("answered_at")
  endedAt         DateTime? @map("ended_at")
  durationSeconds Int?      @map("duration_seconds")

  /// URL da gravação re-hospedada no storage local do CRM (bucket "recordings").
  recordingUrl String? @map("recording_url")

  events CallEvent[]

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, provider, providerCallId])
  @@index([organizationId, contactId])
  @@index([organizationId, dealId])
  @@index([organizationId, direction, status])
  @@index([organizationId, extensionId])
  @@map("calls")
}

/// Evento bruto do webhook, persistido antes de qualquer normalização.
/// Permite reprocessamento e auditoria independente do status de correlação.
model CallEvent {
  id             String @id @default(cuid())
  organizationId String

  callId String? @map("call_id")
  call   Call?   @relation(fields: [callId], references: [id], onDelete: SetNull)

  provider   String
  /// Payload exatamente como chegou no webhook — sem transformação.
  rawPayload Json   @map("raw_payload")

  receivedAt DateTime @default(now()) @map("received_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, callId])
  @@map("call_events")
}

/// Configuração de provedor de telefonia por organização.
/// O `webhookToken` identifica a org no endpoint público de webhook.
model CallProviderConfig {
  id             String @id @default(cuid())
  organizationId String

  /// Identificador do adapter — ex.: "generic-sip", "asterisk".
  providerKey   String @map("provider_key")
  /// Mapeamento de caminhos no payload → campos normalizados.
  fieldMappings Json   @map("field_mappings")

  authMode               WebhookAuthMode
  /// HMAC secret ou token de autenticação — cifrado via encryptSecret().
  webhookSecretEncrypted String          @map("webhook_secret_encrypted")
  /// Header onde a assinatura HMAC é enviada — ex.: "X-Signature-256".
  signatureHeader        String?         @map("signature_header")
  /// Token único na URL pública `/webhooks/calls/:provider?token=<webhookToken>`.
  webhookToken           String          @unique @map("webhook_token")

  recordingDelivery      RecordingDelivery @map("recording_delivery")
  /// Cria contato/lead automaticamente para números desconhecidos.
  createContactsForCalls Boolean           @default(false) @map("create_contacts_for_calls")
  isActive               Boolean           @default(true) @map("is_active")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("call_provider_configs")
}
