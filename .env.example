# ─── Core / deploy ─────────────────────────────────────────────
NODE_ENV=production
PORT=3000
DATABASE_URL=
REDIS_URL=

# URL pública deste backend (NextAuth / cookies / links absolutos gerados no servidor).
NEXTAUTH_URL=https://URL-DO-BACKEND-AQUI

# Use o MESMO valor no frontend (NEXTAUTH_SECRET ou AUTH_SECRET).
NEXTAUTH_SECRET=
AUTH_SECRET=

# true = confiar no Host do proxy (Easypanel / Traefik). false/0 = desliga.
AUTH_TRUST_HOST=true

# Origens do frontend permitidas no CORS (separadas por vírgula, sem espaços extras).
ALLOWED_ORIGINS=https://URL-DO-FRONTEND-AQUI

# Opcional: URL pública em deploy Vercel (fallback em services/channels).
VERCEL_URL=

# ─── Next / runtime ────────────────────────────────────────────
NEXT_RUNTIME=
LOG_LEVEL=

# ─── SSE ───────────────────────────────────────────────────────
SSE_ENABLE_REDIS_PUBSUB=

# ─── Web Push ─────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ─── Meta / WhatsApp ──────────────────────────────────────────
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_ES_CONFIG_ID=
META_WHATSAPP_CALL_PERMISSION_ACCEPT_BUTTON_IDS=
META_WHATSAPP_CALL_PERMISSION_ACCEPT_BUTTON_TITLES=
META_WHATSAPP_CALL_PERMISSION_TEMPLATE=
META_WHATSAPP_CALL_SCHEDULE_TEMPLATE_NAME=
META_WHATSAPP_CALL_SCHEDULE_TEMPLATE_LANG=
META_WHATSAPP_CALL_SCHEDULE_TEMPLATE_COMPONENTS_JSON=

# ─── Criptografia (tokens em canal / secrets) ─────────────────
ENCRYPTION_KEY=

# ─── Automação / filas ─────────────────────────────────────────
AUTOMATION_WORKER_MODE=
AI_AGENT_INACTIVITY_INTERVAL_MS=
AI_AGENT_INACTIVITY_WORKER=
SCHEDULED_MESSAGES_INTERVAL_MS=
SCHEDULED_MESSAGES_WORKER=
STALE_OUTBOUND_TIMEOUT_MS=
STALE_OUTBOUND_SWEEP_INTERVAL_MS=

# ─── Presença / WhatsApp health ────────────────────────────────
PRESENCE_AWAY_MINUTES=
PRESENCE_OFFLINE_MINUTES=
WHATSAPP_HEALTH_TTL_MS=

# ─── IA (OpenAI / Anthropic / transcribe) ─────────────────────
OPENAI_API_KEY=
AI_DEFAULT_MODEL=
AI_EMBEDDING_MODEL=
ANTHROPIC_API_KEY=
AUTOMATION_COPILOT_MODEL=
GROQ_API_KEY=
GROQ_TRANSCRIBE_MODEL=
HUGGINGFACE_API_KEY=
HUGGINGFACE_TRANSCRIBE_MODEL=

# ─── Cron ─────────────────────────────────────────────────────
CRON_SECRET=

# ─── Mídia / timezone ─────────────────────────────────────────
DEFAULT_TIMEZONE=America/Sao_Paulo
NEXT_PUBLIC_WEBRTC_ICE_SERVERS_JSON=
