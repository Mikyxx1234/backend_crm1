# ─── Core / deploy ─────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Modo de execução do container — direciona o entrypoint:
#   api             → Next.js standalone server (default; aplica migrations Prisma)
#   worker-whatsapp → worker BullMQ para campanhas/disparo Meta (campaign-worker)
#   worker-leads    → worker BullMQ para operações em massa de Deals
# Migrations Prisma SÓ rodam quando APP_MODE=api (workers não devem aplicar
# migrations — evita race condition entre serviços do mesmo deploy).
APP_MODE=api

# Opcional: definir como 1 desliga `prisma migrate deploy` no arranque do container.
# SKIP_PRISMA_MIGRATE=

# Nome da base no path (…/NOME?…) deve ser a que contém as tabelas do CRM (ex.: db_crm). Outra base na mesma instância (ex.: "banco") pode existir mas estar vazia — migrates falham com "relation … does not exist".
DATABASE_URL=
REDIS_URL=

# Numero de proxies confiaveis a frente do app (EasyPanel/Traefik = 1,
# Cloudflare + nginx = 2). Usado por getClientIp para escolher o IP
# real do cliente em X-Forwarded-For e evitar spoofing do rate-limit.
TRUSTED_PROXY_HOPS=1

# URL pública deste backend (NextAuth / cookies / links absolutos gerados no servidor).
NEXTAUTH_URL=https://URL-DO-BACKEND-AQUI

# Use o MESMO valor no frontend (NEXTAUTH_SECRET ou AUTH_SECRET).
NEXTAUTH_SECRET=
AUTH_SECRET=

# true = confiar no Host do proxy (Easypanel / Traefik). false/0 = desliga.
AUTH_TRUST_HOST=true

# Origens do frontend permitidas no CORS (separadas por vírgula, sem espaços extras).
ALLOWED_ORIGINS=https://URL-DO-FRONTEND-AQUI

# Opcional: URL pública em deploy Vercel (fallback em services/channels).
VERCEL_URL=

# ─── Next / runtime ────────────────────────────────────────────
NEXT_RUNTIME=
LOG_LEVEL=

# ─── SSE ───────────────────────────────────────────────────────
SSE_ENABLE_REDIS_PUBSUB=

# ─── Web Push ─────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ─── Meta / WhatsApp / Messenger / Instagram ─────────────────
# META_APP_SECRET e META_WEBHOOK_VERIFY_TOKEN sao compartilhados entre
# WhatsApp Cloud, Messenger e Instagram — todos usam o mesmo App Meta do
# CRM. Configure UMA vez e reaproveite nos tres produtos no painel
# developers.facebook.com.
#
# Callback URLs a configurar no App Meta:
#   - WhatsApp        -> https://<backend>/api/webhooks/meta   (ou scoped por org)
#   - Messenger       -> https://<backend>/api/webhooks/meta/messaging
#   - Instagram       -> https://<backend>/api/webhooks/meta/messaging
# Todos com o mesmo Verify Token (META_WEBHOOK_VERIFY_TOKEN).
#
# Permissoes/scopes necessarios (submeter no App Review antes de ir a
# producao): pages_show_list, pages_messaging, pages_manage_metadata,
# business_management, instagram_basic, instagram_manage_messages.
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_ES_CONFIG_ID=
META_WHATSAPP_CALL_PERMISSION_ACCEPT_BUTTON_IDS=
META_WHATSAPP_CALL_PERMISSION_ACCEPT_BUTTON_TITLES=
META_WHATSAPP_CALL_PERMISSION_TEMPLATE=
META_WHATSAPP_CALL_SCHEDULE_TEMPLATE_NAME=
META_WHATSAPP_CALL_SCHEDULE_TEMPLATE_LANG=
META_WHATSAPP_CALL_SCHEDULE_TEMPLATE_COMPONENTS_JSON=

# ─── Criptografia (tokens em canal / secrets) ─────────────────
# Chave AES-256-GCM usada por src/lib/crypto/secrets.ts para
# encriptar tokens em Channel.config, MFA secrets, etc.
# Gere com: openssl rand -base64 32   (44 chars, 32 bytes)
# OBRIGATORIA fora de dev local. O codigo aceita KEYRING_SECRET
# (canonico) OU ENCRYPTION_KEY (alias legado) para nao quebrar
# ambientes ja configurados; prefira KEYRING_SECRET em setups novos.
KEYRING_SECRET=
# ENCRYPTION_KEY=  # alias aceito para back-compat

# ─── Marketplace de widgets (SSO p/ iframes de parceiros) ─────
# Segredo HMAC usado pra assinar/verificar o JWT SSO emitido em
# /api/widgets/:slug/sso-token e validado em
# /api/public/widgets/sso/verify. Deve ter >=32 chars e ser
# INDEPENDENTE do AUTH_SECRET (escopo isolado — comprometer este
# segredo nao expoe sessoes do CRM). Em dev, cai num fallback
# derivado de AUTH_SECRET se ausente.
WIDGET_SSO_SECRET=

# ─── Automação / filas ─────────────────────────────────────────
AUTOMATION_WORKER_MODE=
AI_AGENT_INACTIVITY_INTERVAL_MS=
AI_AGENT_INACTIVITY_WORKER=
SCHEDULED_MESSAGES_INTERVAL_MS=
SCHEDULED_MESSAGES_WORKER=
STALE_OUTBOUND_TIMEOUT_MS=
STALE_OUTBOUND_SWEEP_INTERVAL_MS=

# ─── BullMQ workers: WhatsApp (campaign-worker) ───────────────
# Defaults preservam o comportamento histórico (80 msgs/s, retry x6 com
# backoff exponencial iniciando em 3s). Aumentar com cautela — Meta Cloud
# API impõe seu próprio rate limit por tier e ban temporário em violação.
WHATSAPP_RATE_LIMIT_MAX=80
WHATSAPP_RATE_LIMIT_DURATION=1000
WHATSAPP_MAX_ATTEMPTS=6
WHATSAPP_BACKOFF_DELAY=3000

# ─── BullMQ workers: Leads (operações em massa de Deals) ──────
# Concurrency = quantos jobs em paralelo no MESMO processo worker.
# Cada job processa seus chunks sequencialmente (chunks de 50 deals).
LEADS_BULK_CONCURRENCY=5
LEADS_BULK_MAX_ATTEMPTS=5
LEADS_BULK_BACKOFF_DELAY=5000

# ─── Presença / WhatsApp health ────────────────────────────────
PRESENCE_AWAY_MINUTES=
PRESENCE_OFFLINE_MINUTES=
WHATSAPP_HEALTH_TTL_MS=

# ─── IA (OpenAI / Anthropic / transcribe) ─────────────────────
OPENAI_API_KEY=
AI_DEFAULT_MODEL=
AI_EMBEDDING_MODEL=
ANTHROPIC_API_KEY=
AUTOMATION_COPILOT_MODEL=
GROQ_API_KEY=
GROQ_TRANSCRIBE_MODEL=
HUGGINGFACE_API_KEY=
HUGGINGFACE_TRANSCRIBE_MODEL=

# ─── Cron ─────────────────────────────────────────────────────
CRON_SECRET=

# ─── Observabilidade / Metrics ───────────────────────────────
# Bearer token exigido por GET /api/metrics (Prometheus scrape).
# Sem valor, o endpoint responde 503 — sinal explicito de "desligado".
# Use o MESMO valor no Prometheus (METRICS_TOKEN_DEV/PROD) do
# stack em infra/monitoring/.
METRICS_TOKEN=

# URL da HTTP API do Prometheus, usada por /api/admin/perf-report
# e /api/cron/perf-snapshot para consultas PromQL. Ex:
# http://prometheus:9090 (dentro da rede crm-monitoring).
PROMETHEUS_URL=
# Opcional: bearer token do Prometheus (se protegido por reverse proxy).
PROMETHEUS_TOKEN=

# OpenTelemetry OTLP (opcional; ver src/lib/otel-sdk.ts).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=crm-eduit
OTEL_SERVICE_VERSION=

# ─── Mídia / timezone ─────────────────────────────────────────
DEFAULT_TIMEZONE=America/Sao_Paulo
NEXT_PUBLIC_WEBRTC_ICE_SERVERS_JSON=

# ─── Telefonia Api4com ─────────────────────────────────────────
# Token ADMIN com ttl:-1 da conta de serviço dedicada (gerar via
# POST /users/accessTokens em ambiente fora-do-app). Trocar a senha
# do usuário admin INVALIDA este token. Ver docs/PLAN-api4com.md.
API4COM_SERVICE_TOKEN=
# Identificador do gateway no PATCH /integrations e em metadata.gateway
# de cada /dialer. Default por org pode ser ajustado em CallProviderConfig.
API4COM_GATEWAY=
# Versão do payload do webhook (referência fala "1.8", exemplos usam "v1.4").
API4COM_WEBHOOK_VERSION=v1.4
